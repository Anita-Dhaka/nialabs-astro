---
interface ClientTestimonial {
  clientData: string;
  clientName: string;
  clientAddress: string;
}

interface Props {
  testimonials?: ClientTestimonial[];
  title?: string;
}

const defaultTestimonials: ClientTestimonial[] = [
  {
    clientData: "Since installing Nialabs’ biometric machines in our school, the efficiency of teachers has increased manyfold. Now, they can focus on teaching more rather than marking manual attendance.",
    clientName: "Alpha International", 
    clientAddress: "Jaipur"
  },
  {
    clientData:
      "We were always concerned about the safety of our students and staff’s data if we installed biometrics. With Nialabs, there is no concern about data theft. The assurance and support we got from the team brought us peace of mind.",
    clientName: "Matrix Academy",
    clientAddress: "Sikar",
  },
  {
    clientData:
      "The Biometric Attendance Machine by Nialabs provides a sense of satisfaction. Students and staff love it; they can easily clock in or clock out. Their smooth operation makes the process hassle-free.",
    clientName: "Shamford",
    clientAddress: "Sultanpur",
  },
];

const { 
  testimonials = defaultTestimonials, 
  title = "What Our Clients Say" 
} = Astro.props;
---

<section class="py-10 bg-white" id="testimonials">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-extrabold text-slate-900 tracking-tight">
        {title}
      </h2>
      <div class="mt-4 flex justify-center">
        <div class="w-16 h-1.5 bg-blue-600 rounded-full"></div>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((item) => (
        <div class="flex flex-col h-full p-8 border border-slate-100 rounded-3xl bg-slate-50/50 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-300 relative group">
          <!-- Quote Icon -->
          <div class="absolute top-8 left-8 text-blue-200 group-hover:text-blue-500 transition-colors duration-300">
            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
          </div>

          <blockquote class="flex-grow pt-10">
            <p class="text-slate-600 leading-relaxed italic relative z-10">
              "{item.clientData}"
            </p>
          </blockquote>

          <div class="mt-6 pt-5 border-t border-slate-100 flex items-center gap-4">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white font-bold text-lg shadow-md">
              {item.clientName.charAt(0)}
            </div>
            <div>
              <h3 class="font-bold text-slate-900 leading-tight">{item.clientName}</h3>
              <p class="text-sm text-blue-600 font-medium">{item.clientAddress}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
