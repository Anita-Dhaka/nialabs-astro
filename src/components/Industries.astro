---
const industries = [
  {
    icon: "education",
    head: "Education",
    desc: "Schools, colleges, and other educational institutions.",
  },
  {
    icon: "corporate",
    head: "Corporate and IT",
    desc: "Businesses of all sizes, as well as corporate offices.",
  },
  {
    icon: "factory",
    head: "Manufacturing",
    desc: "Factories and production units can use these systems.",
  },
  {
    icon: "government",
    head: "Government",
    desc: "Government offices, both central and state.",
  },
  {
    icon: "retail",
    head: "Retail",
    desc: "Retail stores can use biometric systems to manage staff.",
  },
  {
    icon: "healthcare",
    head: "Healthcare",
    desc: "Hospitals and clinics can implement biometric systems.",
  },
  {
    icon: "finance",
    head: "Finance and Banking",
    desc: "Banks can use biometric authentication.",
  },
  {
    icon: "visitor",
    head: "Visitor Management",
    desc: "These systems can screen and record visitor information.",
  },
  {
    icon: "canteen",
    head: "Canteen Management",
    desc: "Systems can manage employee meal scans.",
  },
  {
    icon: "gym",
    head: "Gyms and Clubs",
    desc: "Fitness centers can manage member check-ins.",
  },
  {
    icon: "hospitality",
    head: "Hospitality",
    desc: "Hotels and restaurants can use these systems for staff.",
  },
  {
    icon: "logistics",
    head: "Logistics and Transportation",
    desc: "Ensure drivers and crew stay on schedule.",
  },
];

const icons = {
  education: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c3 3 9 3 12 0v-5"/></svg>`,
  corporate: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/></svg>`,
  factory: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M3 7v14M21 7v14M9 21V11M15 21V11M2 7h20M10 3v4M14 3v4"/></svg>`,
  government: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  retail: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4Z"/><path d="M3 6h18M16 10a4 4 0 0 1-8 0"/></svg>`,
  healthcare: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>`,
  finance: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>`,
  visitor: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>`,
  canteen: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8h1a4 4 0 1 1 0 8h-1"/><path d="M3 8h14v9a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4Z"/><line x1="6" y1="2" x2="6" y2="4"/><line x1="10" y1="2" x2="10" y2="4"/><line x1="14" y1="2" x2="14" y2="4"/></svg>`,
  gym: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m6.5 6.5 11 11"/><path d="m11.8 5.8 5.2 5.2"/><path d="m7 11.8 5.2 5.2"/><path d="M5.8 3.5 3.5 5.8"/><path d="m20.5 18.2 2.3 2.3"/><path d="m3.5 18.2 2.3 2.3"/><path d="M18.2 3.5 20.5 5.8"/></svg>`,
  hospitality: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>`,
  logistics: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>`
};
---

<section class="py-10 bg-white" id="industries">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight">
        AI-Powered Solutions Designed <br class="hidden md:block" />
        for <span class="text-blue-600">Your Industry</span>
      </h2>
      <div class="mt-4 flex justify-center">
        <div class="w-16 h-1.5 bg-blue-600 rounded-full"></div>
      </div>
    </div>

    <!-- Industries Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 xl:grid-cols-4 gap-6">
      {industries.map((industry) => (
        <div class="group py-6 lg:px-6 px-0 rounded-2xl border border-slate-100 bg-white hover:bg-slate-50 hover:shadow-xl hover:border-blue-100 transition-all duration-300 flex flex-col items-center text-center">
          <!-- Icon Circle -->
          <div class="mb-5 flex h-14 w-14 items-center justify-center rounded-xl bg-blue-50 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
            <Fragment set:html={icons[industry.icon]} />
          </div>

          <!-- Content -->
          <h3 class="text-lg font-bold text-slate-800 mb-2 group-hover:text-blue-600 transition-colors">
            {industry.head}
          </h3>
          <p class="text-slate-600 text-sm leading-relaxed">
            {industry.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
