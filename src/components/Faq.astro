---
interface FaqItem {
  question: string;
  solution: string;
}

interface Props {
  faqs?: FaqItem[];
  title?: string;
  subtitle?: string;
}

const defaultFaqs: FaqItem[] = [
  {
    question: "What does Nialabs Biometric Solutions specialize in?",
    solution:
      "Nialabs specializes in AI-powered biometric device solutions that transform workforce management through advanced cloud connectivity. With expertise in AI-powered technologies, Nialabs offers a Biometric Device API, a Biometric Attendance API, and advanced biometric systems that enhance security, streamline operations, and improve efficiency across industries.",
  },
  {
    question: "What is a biometric device?",
    solution:
      "A biometric device is a security tool that uses biological characteristics, such as fingerprints or facial features, to identify or recognize a person’s identity. These devices are typically used for purposes like attendance tracking and access control to secure sensitive areas.",
  },
  {
    question: "What types of biometric devices do Nialabs offer?",
    solution:
      "Nialabs offers a wide range of biometric devices, including thumb attendance machines, dynamic face recognition terminals, and biometric devices empowered by AI and cloud APIs. Our biometric solutions are scalable and capable of catering to businesses of all shapes and sizes.",
  },
  {
    question: "Can Nialabs solutions integrate with existing HR platforms?",
    solution:
      "Absolutely, the cloud APIs and biometric solutions at Nialabs are designed to ensure seamless integration. Effortlessly connect your biometric devices with existing HRM systems, payroll systems, and ERP solutions using our biometric attendance API. This creates a unified ecosystem providing real-time updates and helps manage attendance, access control, and workforce data.",
  },
  {
    question: "How secure are Nialabs devices and systems?",
    solution:
      "With AI-driven biometric identification, end-to-end encryption, and multi-factor authentication, security is at the core of our technology. Our solutions empower you with features like real-time biometric login monitoring and customizable access to ensure that you are always in control.",
  },
  {
    question: "What industries can benefit from Nialabs biometric solutions?",
    solution:
      "Nialabs offers versatile biometric solutions that can cater to the needs of businesses across multiple industries, including healthcare, manufacturing, corporate enterprises, education, etc. Any organization, regardless of its scale or strength, that requires accurate attendance tracking, secure access control, and streamlined workforce operations can benefit from our advanced biometric API solutions.",
  },
  {
    question: "Do Nialabs biometric solutions support real-time data updates?",
    solution:
      "Yes, Nialabs leverages real-time biometric software to provide instant updates regarding attendance, access logs, and workforce data. Moreover, our cloud API gives regular updates about the active status of biometric devices. With real-time updates, you can be on top of everything and make better decisions with accurate and up-to-date information.",
  },
  {
    question: "Can I scale the Biometric system as my organization grows?",
    solution:
      "Absolutely! We offer modular and scalable solutions integrated through cloud APIs designed to grow with your business. Whether you're adding devices or expanding on locations or features, the same API can connect all the devices and meet the changing demands of your growing business.",
  },
  {
    question: "How much does a biometric system cost?",
    solution:
      "The biometric device cost depends on various factors, such as the number of thumb machines, features, and integration required. At Nialabs, we offer cost-effective biometric device solutions crafted to meet your needs and ensure you get your hands on premium technology. Plus, our web API can integrate with your existing biometric devices so you won’t have to pay anything extra.",
  },
  {
    question: "What is the future of biometrics?",
    solution:
      "The future of biometrics lies in enhanced security, improved user experience, adoption of contactless systems, AI-driven solutions, and deeper integration with cloud API technologies. As a leader in biometric solutions, Nialabs is at the forefront of this evolution, constantly evolving to meet the biometric needs across India.",
  },
];

const { 
  faqs = defaultFaqs, 
  title = "Frequently Asked Questions",
} = Astro.props;
---

<section class="py-10 bg-slate-50" id="faq">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
        {title}
      </h2>
    </div>

    <div class="space-y-3">
      {faqs.map((faq, index) => (
        <div class="faq-item border border-slate-200 rounded-xl bg-white overflow-hidden transition-all duration-200">
          <button
            class="faq-trigger w-full flex items-center justify-between p-5 text-left transition-colors hover:bg-slate-50"
            aria-expanded="false"
          >
            <span class="font-semibold text-slate-800 pr-4">
              {faq.question}
            </span>
            <svg 
              class="w-5 h-5 text-slate-400 transition-transform duration-300 flex-shrink-0" 
              fill="none" 
              viewBox="0 0 24 24" 
              stroke="currentColor"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </button>
          
          <div class="faq-content max-h-0 opacity-0 overflow-hidden transition-all duration-300 ease-in-out">
            <div class="px-5 pb-5 text-slate-600 leading-relaxed border-t border-slate-50 pt-4 mt-1">
              {faq.solution}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFaq() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const trigger = item.querySelector('.faq-trigger');
      const content = item.querySelector('.faq-content') as HTMLElement;
      const icon = item.querySelector('svg');

      if (!trigger || !content) return;

      trigger.addEventListener('click', () => {
        const isOpen = trigger.getAttribute('aria-expanded') === 'true';
        
        // Toggle
        if (isOpen) {
          trigger.setAttribute('aria-expanded', 'false');
          content.style.maxHeight = '0';
          content.style.opacity = '0';
          icon?.classList.remove('rotate-180');
          item.classList.remove('border-blue-200', 'shadow-sm', 'bg-blue-50/50');
          trigger.classList.remove('bg-blue-50/50', 'text-blue-600');
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          content.style.maxHeight = content.scrollHeight + 'px';
          content.style.opacity = '1';
          icon?.classList.add('rotate-180');
          item.classList.add('border-blue-200', 'shadow-sm', 'bg-blue-50/50');
          trigger.classList.add('bg-blue-50/50', 'text-blue-600');
        }
      });
    });
  }

  // Run on first load
  initFaq();
  // Run on view transitions
  document.addEventListener('astro:after-swap', initFaq);
</script>
