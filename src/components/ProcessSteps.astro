---
interface Step {
  title: string;
  details: string[];
  icon: "enrollment" | "matching" | "capture";
}

interface Props {
  title: string;
  subtitle: string;
  steps: Step[];
}

const { title, subtitle, steps } = Astro.props;

const icons = {
  enrollment: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-blue-600"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  matching: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-blue-600"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>`,
  capture: `<svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-12 h-12 text-blue-600"><rect x="3" y="4" width="18" height="12" rx="2"/><path d="M7 21h10"/><path d="M12 16v5"/></svg>`
};
---

<section class="py-16 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
        {title}
      </h2>
      <div class="w-16 h-1.5 bg-blue-600 rounded-full mx-auto mb-8"></div>
      <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {steps.map((step) => (
        <div class="group relative bg-slate-50/30 rounded-[32px] p-8 md:p-10 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-300">
          <div class="mb-8 flex justify-center lg:justify-start">
            <div class="w-16 h-16 rounded-2xl bg-blue-50 flex items-center justify-center p-4 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
               {step.icon === "enrollment" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M12 21s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 7.2c0 7.3-8 11.8-8 11.8z"/><circle cx="12" cy="9" r="3"/></svg>
               )}
               {step.icon === "matching" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><path d="M7 7h.01"/><path d="M10 7h.01"/><path d="M13 7h.01"/><path d="M17 7h.01"/><path d="M7 10h.01"/><path d="M7 13h.01"/><path d="M7 17h.01"/><rect x="10" y="10" width="7" height="7" rx="1"/></svg>
               )}
               {step.icon === "capture" && (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-8 h-8"><path d="M14.5 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7.5L14.5 2z"/><polyline points="14 2 14 8 20 8"/><path d="M16 13H8"/><path d="M16 17H8"/><path d="M10 9H8"/></svg>
               )}
            </div>
          </div>
          
          <h3 class="text-xl md:text-2xl font-extrabold text-slate-900 mb-6 text-center lg:text-left leading-tight group-hover:text-blue-600 transition-colors">
            {step.title}
          </h3>
          
          <div class="space-y-4">
            {step.details.map((detail) => (
              <p class="text-slate-600 font-medium leading-relaxed text-center lg:text-left text-sm md:text-base">
                {detail}
              </p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
