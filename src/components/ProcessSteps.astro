---
interface Step {
  title: string;
  details: string[];
  icon: "enrollment" | "matching" | "capture";
}

interface Props {
  title: string;
  subtitle: string;
  steps: Step[];
}

const { title, subtitle, steps } = Astro.props;
---

<section class="py-16 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center max-w-3xl mx-auto mb-20">
      <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 mb-6 leading-tight">
        {title}
      </h2>
      <div class="w-16 h-1.5 bg-blue-600 rounded-full mx-auto mb-8"></div>
      <p class="text-lg md:text-xl text-slate-600 font-medium leading-relaxed">
        {subtitle}
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative">

      <!-- Dashed connector line (desktop only) -->
      <div class="hidden lg:block absolute top-[90px] left-[calc(16.66%+2rem)] right-[calc(16.66%+2rem)] h-px border-t-2 border-dashed border-blue-200 pointer-events-none" />

      {steps.map((step, index) => (
        <div class="group relative bg-slate-50/30 rounded-[32px] p-8 md:p-10 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-300">

          <!-- Step circle -->
          <div class="mb-8 flex justify-center">
            <div class="relative w-[6.5rem] h-[6.5rem] rounded-full bg-blue-50 border-2 border-blue-200 flex flex-col items-center justify-center group-hover:bg-blue-600 group-hover:border-blue-600 transition-all duration-300">
              <span class="text-[11px] font-bold tracking-widest uppercase text-blue-300 group-hover:text-blue-200 leading-none transition-colors">
                STEP
              </span>
              <span class="text-[2.5rem] font-extrabold text-blue-600 group-hover:text-white leading-none transition-colors">
                {index + 1}
              </span>
              <!-- Rotating dashed ring -->
              <div class="absolute inset-[-4px] rounded-full border border-dashed border-blue-200 group-hover:border-white/40 transition-colors animate-spin-slow" />
            </div>
          </div>

          <h3 class="text-xl md:text-2xl font-extrabold text-slate-900 mb-6 text-center lg:text-left leading-tight group-hover:text-blue-600 transition-colors">
            {step.title}
          </h3>

          <div class="space-y-4">
            {step.details.map((detail) => (
              <p class="text-slate-600 font-medium leading-relaxed text-center lg:text-left text-sm md:text-base">
                {detail}
              </p>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>