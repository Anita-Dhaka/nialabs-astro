---
const comparisonData = {
  education: {
    challenges: [
      {
        icon: "error",
        head: "Manual Attendance Errors",
        text: "Teachers spend valuable time marking attendance manually.",
      },
      {
        icon: "proxy",
        head: "Proxy & Manipulated Attendance",
        text: "Students can easily mark proxies for friends without detection.",
      },
      {
        icon: "no-view",
        head: "No Real-Time Visibility",
        text: "Parents have no instant updates on their child's presence.",
      },
      {
        icon: "admin",
        head: "Time-Consuming Administration",
        text: "Non-automated attendance consumes hours of administrative time.",
      },
      {
        icon: "report",
        head: "Chaotic Report Generation",
        text: "Compiling attendance data manually is inaccurate and hectic.",
      },
    ],
    solutions: [
      {
        icon: "robot",
        head: "Automated Biometrics",
        text: "Records attendance instantly and accurately—no manual entry, no errors.",
      },
      {
        icon: "face-id",
        head: "AI-Based Face Recognition",
        text: "Detects live faces, preventing photo-based or proxy attendance.",
      },
      {
        icon: "notify",
        head: "Instant Parent Notifications",
        text: "Parents receive automatic SMS or app alerts immediately.",
      },
      {
