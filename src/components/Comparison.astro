---

<section class="py-10 bg-white" id="comparison">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight">
        Why Traditional Attendance Systems <br class="hidden md:block" />
        <span class="text-red-600">No Longer Work</span>
      </h2>
      <p class="mt-4 text-lg text-slate-600 max-w-3xl mx-auto">
        From schools to offices, manual or outdated attendance-tracking systems lead to inefficiency, data errors, and security risks. Here’s what organizations face without a biometric system.
      </p>
    </div>

    <!-- Tab Switcher -->
    <div class="flex justify-center mb-16">
      <div class="inline-flex p-1 bg-slate-100 rounded-2xl shadow-inner">
        <button 
          id="tab-education"
          class="px-8 py-3 rounded-xl font-bold text-sm transition-all duration-300 bg-white text-blue-600 shadow-sm"
          onclick="switchTab('education')"
        >
          Educational Institutions
        </button>
        <button 
          id="tab-business"
          class="px-8 py-3 rounded-xl font-bold text-sm transition-all duration-300 text-slate-500 hover:text-slate-700"
          onclick="switchTab('business')"
        >
          Businesses & Organizations
        </button>
      </div>
    </div>

    <!-- Comparison Panels -->
    <div class="relative min-h-[600px]">
      <!-- Education Section -->
      <div id="panel-education" class="transition-all duration-500 opacity-100 block">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 rounded-[40px] overflow-hidden border border-slate-100 shadow-2xl">
          <!-- Challenges (Left) -->
          <div class="bg-red-50/50 p-8 md:p-12 border-b lg:border-b-0 lg:border-r border-red-100">
            <h3 class="text-2xl font-bold text-red-900 mb-8 flex items-center gap-3">
              <span class="p-2 bg-red-100 text-red-600 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </span>
              Challenges Faced
            </h3>
            <div class="space-y-6">
              {comparisonData.education.challenges.map((item) => (
                <div class="flex gap-4 group">
                  <div class="flex-none p-2 rounded-lg bg-orange-100/50 text-orange-600 h-10 w-10 flex items-center justify-center">
                    <Fragment set:html={icons[item.icon]} />
                  </div>
                  <div>
                    <h4 class="font-bold text-slate-800 mb-1">{item.head}</h4>
                    <p class="text-sm text-slate-600">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
          <!-- Solutions (Right) -->
          <div class="bg-slate-700 p-8 md:p-12 text-white relative">
            <h3 class="text-2xl font-bold mb-8 flex items-center gap-3">
              <span class="p-2 bg-slate-600 text-white rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Nialabs Smart Solutions
            </h3>
            <div class="space-y-6">
              {comparisonData.education.solutions.map((item) => (
                <div class="flex gap-4 group">
                  <div class="flex-none p-2 rounded-lg bg-slate-600 text-white border border-slate-400 h-10 w-10 flex items-center justify-center">
                    <Fragment set:html={icons[item.icon]} />
                  </div>
                  <div>
                    <h4 class="font-bold text-white mb-1">{item.head}</h4>
                    <p class="text-sm text-blue-50">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
            
            <!-- Background Decoration -->
            <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-blue-500 rounded-full opacity-20 blur-3xl"></div>
          </div>
        </div>
      </div>

      <!-- Business Section -->
      <div id="panel-business" class="transition-all duration-500 opacity-0 hidden">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 rounded-[40px] overflow-hidden border border-slate-100 shadow-2xl">
          <!-- Challenges (Left) -->
          <div class="bg-red-50/50 p-8 md:p-12 border-b lg:border-b-0 lg:border-r border-red-100">
            <h3 class="text-2xl font-bold text-red-900 mb-8 flex items-center gap-3">
              <span class="p-2 bg-red-100 text-red-600 rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
              </span>
              Challenges Faced
            </h3>
            <div class="space-y-6">
              {comparisonData.business.challenges.map((item) => (
                <div class="flex gap-4 group">
                  <div class="flex-none p-2 rounded-lg bg-orange-100/50 text-orange-600 h-10 w-10 flex items-center justify-center">
                    <Fragment set:html={icons[item.icon]} />
                  </div>
                  <div>
                    <h4 class="font-bold text-slate-800 mb-1">{item.head}</h4>
                    <p class="text-sm text-slate-600">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>
          
          <!-- Solutions (Right) -->
          <div class="bg-slate-700 p-8 md:p-12 text-white relative">
            <h3 class="text-2xl font-bold mb-8 flex items-center gap-3">
              <span class="p-2 bg-slate-600 text-white rounded-lg">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
              </span>
              Nialabs Smart Solutions
            </h3>
            <div class="space-y-6">
              {comparisonData.business.solutions.map((item) => (
                <div class="flex gap-4 group">
                  <div class="flex-none p-2 rounded-lg bg-slate-600 border border-slate-700 text-blue-400 h-10 w-10 flex items-center justify-center">
                    <Fragment set:html={icons[item.icon]} />
                  </div>
                  <div>
                    <h4 class="font-bold text-white mb-1">{item.head}</h4>
                    <p class="text-sm text-slate-400">{item.text}</p>
                  </div>
                </div>
              ))}
            </div>
            <!-- Background Decoration -->
            <div class="absolute -bottom-10 -right-10 w-64 h-64 bg-blue-600 rounded-full opacity-10 blur-3xl"></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  function switchTab(type) {
    const panels = {
      education: document.getElementById('panel-education'),
      business: document.getElementById('panel-business')
    };
    const tabs = {
      education: document.getElementById('tab-education'),
      business: document.getElementById('tab-business')
    };

    if (type === 'education') {
      panels.education.classList.remove('hidden', 'opacity-0');
      panels.education.classList.add('block', 'opacity-100');
      panels.business.classList.add('hidden', 'opacity-0');
      panels.business.classList.remove('block', 'opacity-100');

      tabs.education.classList.add('bg-white', 'text-blue-600', 'shadow-sm');
      tabs.education.classList.remove('text-slate-500');
      tabs.business.classList.remove('bg-white', 'text-blue-600', 'shadow-sm');
      tabs.business.classList.add('text-slate-500');
    } else {
      panels.business.classList.remove('hidden', 'opacity-0');
      panels.business.classList.add('block', 'opacity-100');
      panels.education.classList.add('hidden', 'opacity-0');
      panels.education.classList.remove('block', 'opacity-100');

      tabs.business.classList.add('bg-white', 'text-blue-600', 'shadow-sm');
      tabs.business.classList.remove('text-slate-500');
      tabs.education.classList.remove('bg-white', 'text-blue-600', 'shadow-sm');
      tabs.education.classList.add('text-slate-500');
    }
  }
</script>
