    ]
  },
  business: {
    challenges: [
      {
        icon: "workforce",
        head: "Inefficient Management",
        text: "Manual attendance makes it hard to track and manage employees.",
      },
      {
        icon: "payroll",
        head: "Payroll Inaccuracies",
        text: "Lagging or incorrect data leads to salary errors and overpayments.",
      },
      {
        icon: "buddy",
        head: "Attendance Manipulation",
        text: "Employees can mark attendance on behalf of others easily.",
      },
      {
        icon: "metrics",
        head: "Lack of Data Insights",
        text: "Difficult to measure performance, absenteeism, or overtime trends.",
      },
      {
        icon: "security",
        head: "Security & Access Concerns",
        text: "Unmonitored entries create significant security risks for premises.",
      },
    ],
    solutions: [
      {
        icon: "ai-track",
        head: "AI-Powered Tracking",
        text: "Automate attendance to ensure real-time employee tracking.",
      },
      {
        icon: "integration",
        head: "Seamless Payroll Integration",
        text: "Attendance data syncs directly with major payroll software.",
      },
      {
        icon: "access",
        head: "Live Face Access Control",
        text: "Prevent 'buddy punching' with biometric verification.",
      },
      {
        icon: "dashboard",
        head: "Advanced Analytics",
        text: "Get real-time reports on attendance trends and absenteeism.",
      },
      {
        icon: "gatekeeper",
        head: "Integrated Access System",
        text: "Control all entry and exit points with biometric verification.",
      },
    ]
  }
};

const icons = {
  // Challenges (Amber/Red)
  error: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
  proxy: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  "no-view": `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"/><line x1="1" y1="1" x2="23" y2="23"/></svg>`,
