---
const slides = [
  {
    img: "/headerImages/409.webp",
    phoneImg: "/headerImages/p412.webp",
    h1: "AI Powered",
    h2: "Biometric Attendance",
    h3: "for Smarter Schools",
    subHeading: "Revolutionize student and staff attendance with Nialabs’ AI-driven biometric systems designed for schools, colleges, and coaching institutes. Get real-time reports, ensure accuracy, and simplify campus management with one smart solution.",
    linkText: "Explore School Solutions",
    stats: "1000+ schools & enterprises",
  },
  {
    img: "/headerImages/410.webp",
    phoneImg: "/headerImages/p413.webp",
    h1: "Smart Biometric",
    h2: "Attendance Systems",
    h3: "for Modern Workplaces",
    subHeading: "Empower your organization with secure, cloud-connected biometric solutions from Nialabs. Automate workforce attendance, manage access control, and get AI-powered insights, built for MSMEs, enterprises, and government offices.",
    linkText: "Discover Business Solutions",
    stats: "3000+ Satisfied Clients",
  },
  {
    img: "/headerImages/411.webp",
    phoneImg: "/headerImages/p414.webp",
    h1: "Smart Bus",
    h2: "Biometric Attendance",
    h3: "Safety Beyond the Campus",
    subHeading: "Simplify student commute tracking with Nialabs’ smart bus attendance solution: automatic biometric check-in/check-out, real-time GPS tracking, and instant parent notifications, built for schools, colleges & coaching institutes.",
    linkText: "Learn About Bus Solutions",
    stats: "1000+ schools & enterprises",
  },
  {
    img: "/headerImages/415.webp",
    phoneImg: "/headerImages/415.webp",
    noText: true,
    mobileH1: "Smart Identity &",
    mobileH2: "Access Solutions",
    mobileSubHeading: "Explore our Face Biometric Devices to Turnstiles, All your Access needs in one place",
    mobileLinkText: "Explore Our Solutions",
    mobileStats: "3000+ Satisfied Clients",
  },
];
---

<section class="relative w-full h-[500px] md:h-[550px] lg:h-[600px] overflow-hidden bg-slate-900 border-b border-slate-800">
  <!-- Slider Container -->
  <div id="hero-slider" class="relative w-full h-full">
    {slides.map((slide, index) => (
      <div 
        class={`hero-slide absolute inset-0 transition-opacity duration-1000 ease-in-out ${index === 0 ? 'opacity-100' : 'opacity-0 pointer-events-none'}`}
        data-index={index}
      >
        <!-- Background Images (Responsive) -->
        <picture class={slide.noText ? 'hidden md:block w-full h-full' : ''}>
          <source media="(max-width: 768px)" srcset={slide.phoneImg} />
          <img 
            src={slide.img} 
            alt={slide.h2 || "Nialabs Biometric Solutions"} 
            class="w-full h-full object-cover"
          />
        </picture>

        <!-- Mobile-only content for 4th slide (no image, styled bg) -->
        {slide.noText && (
          <div class="md:hidden absolute inset-0 bg-slate-900 flex items-center">
            <div class="max-w-7xl mx-auto w-full px-6 flex flex-col justify-center">
              <div class="slide-content-reveal">
                <div class="space-y-1 mb-4">
                  <h1 class="text-3xl font-extrabold text-white leading-tight">
                    {slide.mobileH1}
                  </h1>
                  <p class="text-2xl font-bold text-blue-400 leading-tight">
                    {slide.mobileH2}
                  </p>
                </div>
                <p class="text-sm text-slate-200 mb-6 leading-relaxed">
                  {slide.mobileSubHeading}
                </p>
                <div class="mb-5">
                  <span class="text-blue-400 font-bold border-b-2 border-blue-400 pb-1 text-sm">
                    {slide.mobileLinkText}
                  </span>
                </div>
                <div class="flex flex-wrap gap-4 mb-6">
                  <a 
                    href="/biometric-devices" 
                    class="px-6 py-2 bg-white text-slate-900 font-bold rounded-lg border-2 border-white hover:bg-transparent hover:text-white hover:scale-[1.02] transition-all duration-300 text-sm"
                  >
                    Request Demo
                  </a>
                  <a 
                    href="/products/biometric-attendance-machine" 
                    class="px-6 py-2 bg-transparent text-white font-bold rounded-lg border-2 border-white hover:bg-white hover:text-slate-900 hover:scale-[1.02] transition-all duration-300 text-sm"
                  >
                    View Product Gallery
                  </a>
                </div>
                <p class="text-slate-300 text-xs flex items-center gap-2">
                  Trusted by <span class="text-white font-extrabold">{slide.mobileStats}</span> Across India
                </p>
              </div>
            </div>
          </div>
        )}

        <!-- Content Overlay -->
        {!slide.noText && (
          <div class="absolute inset-0 bg-gradient-to-r from-slate-900/80 via-slate-900/40 to-transparent">
            <div class="max-w-7xl mx-auto h-full px-4 sm:px-6 lg:px-8 flex flex-col justify-start pt-4 md:pt-4 lg:pt-8">
              <div class="max-w-2xl transform transition-all duration-700 translate-y-8 opacity-0 slide-content-reveal">
                <!-- Titles -->
                <div class="space-y-1 mb-4">
                  {index === 0 ? (
                    <h1 class="text-2xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
                      {slide.h1}
                    </h1>
                  ) : (
                    <p class="text-2xl md:text-4xl lg:text-5xl font-extrabold text-white leading-tight">
                      {slide.h1}
                    </p>
                  )}
                  <p class="text-xl md:text-3xl lg:text-4xl font-bold text-white leading-tight">
                    {slide.h2}
                  </p>
                  <p class="text-lg md:text-2xl lg:text-3xl font-semibold text-blue-400 leading-tight">
                    {slide.h3}
                  </p>
                </div>

                <!-- Subheading -->
                <p class="text-base hidden md:block md:text-lg text-slate-200 mb-6 leading-relaxed max-w-xl line-clamp-3 md:line-clamp-none">
                  {slide.subHeading}
                </p>
                <div class="block md:hidden mb-20"> </div>

                <!-- Link Text -->
                <div class="mb-6 ">
                  <span class="text-blue-400 font-bold border-b-2 border-blue-400 pb-1 cursor-default text-sm md:text-base">
                    {slide.linkText}
                  </span>
                </div>

                <!-- Buttons -->
                <div class="flex flex-wrap gap-4 mb-8">
                  <a 
                    href="/biometric-devices" 
                    class="px-6 py-2 md:px-8 md:py-3 bg-white text-slate-900 font-bold rounded-lg border-2 border-white hover:bg-transparent hover:text-white hover:scale-[1.02] transition-all duration-300 text-sm md:text-base"
                  >
                    Request Demo
                  </a>
                  <a 
                    href="/products/biometric-attendance-machine" 
                    class="px-6 py-2 md:px-8 md:py-3 bg-transparent text-white font-bold rounded-lg border-2 border-white hover:bg-white hover:text-slate-900 hover:scale-[1.02] transition-all duration-300 text-sm md:text-base"
                  >
                    View Product Gallery
                  </a>
                </div>

                <!-- Trust Stats -->
                <p class="text-slate-300 text-xs md:text-sm flex items-center gap-2">
                  Trusted by <span class="text-white font-extrabold">{slide.stats}</span> Across India
                </p>
              </div>
            </div>
          </div>
        )}
      </div>
    ))}
  </div>

  <!-- Navigation Arrows -->
  <button 
    id="prev-slide" 
    class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center rounded-full bg-black/20 text-white hover:bg-blue-600 transition-all duration-300 z-20 group"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
    </svg>
  </button>
  <button 
    id="next-slide" 
    class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center rounded-full bg-black/20 text-white hover:bg-blue-600 transition-all duration-300 z-20 group"
  >
    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </button>

  <!-- Dots (Pointers) -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-20">
    {slides.map((_, index) => (
      <button 
        class={`hero-dot w-3 h-3 rounded-full transition-all duration-300 ${index === 0 ? 'bg-blue-600 w-8' : 'bg-white/50 hover:bg-white'}`}
        data-index={index}
      ></button>
    ))}
  </div>
</section>

<style>
  .slide-content-reveal {
    animation: slideUpFade 0.8s ease-out forwards;
  }

  @keyframes slideUpFade {
    from {
      opacity: 0;
      transform: translateY(30px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero-slide {
    transition: opacity 1s ease-in-out;
  }
</style>

<script is:inline>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.hero-slide');
  const dots = document.querySelectorAll('.hero-dot');
  const totalSlides = slides.length;

  function showSlide(index) {
    slides.forEach((slide, i) => {
      if (i === index) {
        slide.classList.remove('opacity-0', 'pointer-events-none');
        slide.classList.add('opacity-100');
        // Restart animation
        const content = slide.querySelector('.slide-content-reveal');
        if (content) {
          content.style.animation = 'none';
          content.offsetHeight; // force reflow
          content.style.animation = null;
        }
      } else {
        slide.classList.add('opacity-0', 'pointer-events-none');
        slide.classList.remove('opacity-100');
      }
    });

    dots.forEach((dot, i) => {
      if (i === index) {
        dot.classList.add('bg-blue-600', 'w-8');
        dot.classList.remove('bg-white/50');
      } else {
        dot.classList.remove('bg-blue-600', 'w-8');
        dot.classList.add('bg-white/50');
      }
    });

    currentSlide = index;
  }

  function nextSlide() {
    let next = (currentSlide + 1) % totalSlides;
    showSlide(next);
  }

  function prevSlide() {
    let prev = (currentSlide - 1 + totalSlides) % totalSlides;
    showSlide(prev);
  }

  // Event Listeners
  document.getElementById('next-slide').addEventListener('click', nextSlide);
  document.getElementById('prev-slide').addEventListener('click', prevSlide);

  dots.forEach(dot => {
    dot.addEventListener('click', () => {
      const index = parseInt(dot.getAttribute('data-index'));
      showSlide(index);
    });
  });

  // Auto Play
  let slideInterval = setInterval(nextSlide, 5000);

  // Pause on hover
  const sliderContainer = document.getElementById('hero-slider');
  sliderContainer.addEventListener('mouseenter', () => clearInterval(slideInterval));
  sliderContainer.addEventListener('mouseleave', () => slideInterval = setInterval(nextSlide, 5000));
</script>
