---
const stats = [
  { numbers: '1M+', stats: 'Punches handled every day' },
  { numbers: '3000+', stats: 'Satisfied Clients' },
  { numbers: '4+', stats: 'Years of dedicated service' },
  { numbers: '5500+', stats: 'Biometrics Sold and Installed' },
  { numbers: '750+', stats: 'Biometrics Installed in School Buses' },
  { numbers: '250+', stats: 'Trusted Partners' },
];
---

<div id="contactPopupOverlay" class="fixed inset-0 z-50 flex items-center justify-center p-4 sm:p-6 opacity-0 pointer-events-none transition-opacity duration-500 bg-slate-900/60 backdrop-blur-sm">
  
  <!-- Modal Content -->
  <div id="contactPopupModal" class="relative w-full max-w-[900px] bg-white rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-all duration-500 flex flex-col max-h-[90vh]">
    
    <!-- Close Button -->
    <button id="closePopupBtn" class="absolute top-4 right-4 z-10 w-10 h-10 flex items-center justify-center rounded-full bg-slate-100/50 hover:bg-slate-200 text-slate-500 hover:text-slate-700 transition-colors" aria-label="Close popup">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    
    <div class="flex flex-col lg:flex-row h-full overflow-y-auto overflow-x-hidden">
      
      <!-- Left Column (Stats) - Hidden on mobile -->
      <div class="hidden lg:flex lg:w-[45%] bg-gradient-to-br from-blue-600 to-indigo-700 p-8 flex-col text-white relative">
        <div class="absolute inset-0 bg-[url('/mainImages/grid.svg')] bg-center opacity-10"></div>
        <div class="relative z-10 h-full flex flex-col justify-between overflow-hidden">
          <div class="mb-6">
            <h2 class="text-2xl lg:text-3xl font-extrabold tracking-tight mb-3 text-white leading-tight">Transform the Way You Manage Attendance & Security</h2>
            <p class="text-blue-100 text-base leading-relaxed font-medium">Experience Nialabs' proven biometric technology powering 1M+ punches daily across schools, offices, and enterprises.</p>
          </div>
          
          <div class="space-y-4">
            {stats.map((item) => (
              <div class="flex items-center gap-3">
                <div class="w-8 h-8 rounded-lg bg-white/10 flex items-center justify-center border border-white/20 shrink-0">
                  <svg class="h-4 w-4 text-blue-200" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                </div>
                <div class="flex items-center gap-2 flex-wrap">
                  <div class="text-xl font-black text-white">{item.numbers}</div>
                  <div class="text-sm text-blue-200 tracking-wide font-medium">{item.stats}</div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Right Column (Form) -->
      <div class="w-full lg:w-[55%] p-6 sm:p-8 flex flex-col justify-center">
        <!-- Mobile Header -->
        <div class="lg:hidden text-center mb-6">
          <h2 class="text-xl font-extrabold tracking-tight mb-1 text-slate-900 leading-tight">Transform the Way You Manage Attendance & Security</h2>
          <p class="text-slate-600 font-medium text-xs">Experience Nialabs' proven technology powering 1M+ punches daily.</p>
        </div>

        <form id="popupContactForm" class="space-y-4">
          <div>
            <label for="popupName" class="block text-xs font-bold text-slate-700 mb-1 uppercase tracking-wide">Name <span class="text-red-500">*</span></label>
            <input type="text" id="popupName" name="name" placeholder="Enter your name" required minlength="2"
              class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium" />
          </div>

          <div>
            <label for="popupEmail" class="block text-xs font-bold text-slate-700 mb-1 uppercase tracking-wide">Email <span class="text-red-500">*</span></label>
            <input type="email" id="popupEmail" name="email" placeholder="Enter your email" required pattern="[a-z0-9._%+-]+@[a-z0-9.-]+\.[a-z]{2,}$"
              class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium" />
          </div>

          <div>
            <label for="popupContact" class="block text-xs font-bold text-slate-700 mb-1 uppercase tracking-wide">Contact <span class="text-red-500">*</span></label>
            <input type="tel" id="popupContact" name="contact" placeholder="10-digit phone number" required pattern="[0-9]{10}"
              class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium" />
            <p class="mt-1 text-[10px] text-slate-500 hidden" id="popupContactError">Please enter a valid 10-digit phone number.</p>
          </div>

          <div>
            <label for="popupMessage" class="block text-xs font-bold text-slate-700 mb-1 uppercase tracking-wide">Message <span class="text-red-500">*</span></label>
            <textarea id="popupMessage" name="message" rows="2" placeholder="Enter your message" required minlength="10"
              class="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded-lg text-sm text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium resize-none"></textarea>
          </div>

          <div class="pt-1 flex gap-3">
            <button type="button" id="popupCancelBtn" class="w-1/3 py-2.5 bg-slate-50 hover:bg-slate-100 text-slate-600 font-bold rounded-lg border border-slate-200 transition-colors text-sm">
              Close
            </button>
            <button type="submit" id="popupSubmitBtn" class="w-2/3 py-2.5 bg-[#2067e2] hover:bg-blue-700 text-white font-extrabold text-sm rounded-lg shadow-lg shadow-blue-500/25 transform transition-all active:scale-[0.98] flex items-center justify-center gap-2">
              <span id="popupBtnText">Submit</span>
              <svg id="popupLoadingIcon" class="hidden animate-spin h-4 w-4 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
            </button>
          </div>

          <div id="popupFormStatus" class="hidden p-2 rounded-lg text-center font-bold text-xs mt-2"></div>
        </form>

      </div>
    </div>
  </div>
</div>

<script>
  let hasShownPopup = false;

  const overlay = document.getElementById('contactPopupOverlay');
  const modal = document.getElementById('contactPopupModal');
  const closeBtn = document.getElementById('closePopupBtn');
  const cancelBtn = document.getElementById('popupCancelBtn');
  
  const form = document.getElementById('popupContactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('popupSubmitBtn') as HTMLButtonElement;
  const btnText = document.getElementById('popupBtnText');
  const loadingIcon = document.getElementById('popupLoadingIcon');
  const formStatus = document.getElementById('popupFormStatus');
  const contactInput = document.getElementById('popupContact') as HTMLInputElement;
  const contactError = document.getElementById('popupContactError');

  // Input validation UI
  contactInput?.addEventListener('input', () => {
    if (contactInput.validity.patternMismatch) {
      contactError?.classList.remove('hidden');
      contactInput.classList.add('border-red-500');
    } else {
      contactError?.classList.add('hidden');
      contactInput.classList.remove('border-red-500');
    }
  });

  const showPopup = () => {
    if(hasShownPopup) return;
    
    // Show overlay
    overlay?.classList.remove('opacity-0', 'pointer-events-none');
    overlay?.classList.add('opacity-100');
    
    // Animate modal in
    modal?.classList.remove('scale-95');
    modal?.classList.add('scale-100');
    
    hasShownPopup = true;
  };

  const closePopup = () => {
    // Hide overlay
    overlay?.classList.add('opacity-0', 'pointer-events-none');
    overlay?.classList.remove('opacity-100');
    
    // Animate modal out
    modal?.classList.add('scale-95');
    modal?.classList.remove('scale-100');
  };

  closeBtn?.addEventListener('click', closePopup);
  cancelBtn?.addEventListener('click', closePopup);
  
  // Close on outside click
  overlay?.addEventListener('click', (e) => {
    if (e.target === overlay) closePopup();
  });

  // Setup IntersectionObserver for the Testimonials section
  if (typeof window !== 'undefined' && !hasShownPopup) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting && !hasShownPopup) {
          // Add a tiny delay to ensure a smooth read before popping up
          setTimeout(() => {
            showPopup();
          }, 500);
          observer.disconnect();
        }
      });
    }, { threshold: 0.3 }); // Trigger when 30% of the section is visible

    // We observe the testimonials section. If it doesn't exist, we fallback to page bottom.
    const testimonialsSection = document.getElementById('testimonials');
    if (testimonialsSection) {
      observer.observe(testimonialsSection);
    } else {
      // Fallback scroll listener if #testimonials is missing
      window.addEventListener('scroll', function scrollHandler() {
        const scrollPosition = window.innerHeight + window.scrollY;
        const pageHeight = document.documentElement.scrollHeight;
        if (scrollPosition >= pageHeight - 200 && !hasShownPopup) {
          showPopup();
          window.removeEventListener('scroll', scrollHandler);
        }
      });
    }
  }

  // Handle form submission
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Set loading state
    submitBtn.disabled = true;
    if(btnText) btnText.textContent = 'Submitting...';
    loadingIcon?.classList.remove('hidden');
    formStatus?.classList.add('hidden');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    const payload = {
      leadListId: "68b53c175188bd06232e87ea",
      name: data.name || "",
      email: data.email || "",
      contact1: data.contact || "",
      customFields: [
        {
          customFieldId: "68b53c9b5188bd06232e96a9",
          key: "nialabs_message",
          value: data.message || ""
        }
      ]
    };

    try {
      const response = await fetch("https://api.next.coachinglog.in/api/v1/lead/website", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "iid": "6502a77c6d074427b15f5230"
        },
        body: JSON.stringify(payload)
      });

      if (response.ok) {
        if(formStatus) {
            formStatus.textContent = "Form submitted successfully!";
            formStatus.className = "p-3 mt-4 rounded-lg flex items-center justify-center gap-2 text-green-700 bg-green-50 border border-green-200 block";
        }
        form.reset();
        
        // Auto close after 2 seconds
        setTimeout(() => {
          closePopup();
        }, 2000);
      } else {
        throw new Error('API request failed');
      }
    } catch (err) {
      if(formStatus) {
        formStatus.textContent = "Failed to submit form. Please try again.";
        formStatus.className = "p-3 mt-4 rounded-lg flex items-center justify-center gap-2 text-red-700 bg-red-50 border border-red-200 block";
      }
    } finally {
      submitBtn.disabled = false;
      if(btnText) btnText.textContent = 'Submit';
      loadingIcon?.classList.add('hidden');
    }
  });

</script>
