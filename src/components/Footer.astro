      <!-- Right Column: Vertical Link Grids -->
      <div class="flex-grow pt-4">
        <div
          class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-3 gap-8 lg:gap-10"
        >
          {/* Company Section */}
          <div>
            <h3
              class="text-sm font-semibold text-white tracking-wider uppercase mb-6"
            >
              {footerData[0].title}
            </h3>
            <ul class="flex flex-col space-y-4">
              {
                footerData[0].data.map((item) => (
                  <li>
                    <a
                      href={item.link}
                      class="text-sm text-slate-300 hover:text-blue-400 hover:translate-x-1 inline-block transition-all duration-200"
                    >
                      {item.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Column 2: Products & Solutions -->
          <div>
            <h3
              class="text-sm font-semibold text-white tracking-wider uppercase mb-6"
            >
              {footerData[1].title}
            </h3>
            <ul class="flex flex-col space-y-4">
              {
                footerData[1].data.map((item) => (
                  <li>
                    <a
                      href={item.link}
                      class="text-sm text-slate-300 hover:text-blue-400 hover:translate-x-1 inline-block transition-all duration-200"
