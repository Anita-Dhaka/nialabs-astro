                      {item.title}
                    </a>
                  </li>
                ))
              }
            </ul>
          </div>

          <!-- Column 3: Legal -->
          <div>
            <h3
              class="text-sm font-semibold text-white tracking-wider uppercase mb-6"
            >
              {footerData[2].title}
            </h3>
            <ul class="flex flex-col space-y-4">
              {
                footerData[2].data.map((item) => (
