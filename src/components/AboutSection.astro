---
const stats = [
  {
    icon: "punch",
    bold: "1M+",
    text: "Punches handled \nevery day",
  },
  {
    icon: "clients",
    bold: "3000+",
    text: "Satisfied Clients",
  },
  {
    icon: "years",
    bold: "4+",
    text: "Years of \ndedicated service",
  },
  {
    icon: "installed",
    bold: "5500+",
    text: "Biometrics Sold\n and Installed",
  },
  {
    icon: "bus",
    bold: "750+",
    text: "Biometrics Installed\n in School Buses",
  },
  { 
    icon: "partner",
    bold: "250+", 
    text: "Trusted Partners" 
  },
];

const icons = {
  punch: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 11V6a2 2 0 0 0-2-2H4a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h3"/><path d="M10 19v-5a2 2 0 0 1 2-2h7a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-7a2 2 0 0 1-2-2Z"/><path d="M14 15v2"/><path d="M18 15v2"/></svg>`,
  clients: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  years: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  installed: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m2 7 4.41-4.41A2 2 0 0 1 7.83 2h8.34a2 2 0 0 1 1.42.59L22 7"/><rect width="20" height="11" x="2" y="7" rx="2"/><path d="M10 14h4"/><path d="M12 11v6"/></svg>`,
  bus: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="10" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/><circle cx="7" cy="21" r="2"/><circle cx="17" cy="21" r="2"/><path d="M12 16v2"/></svg>`,
  partner: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M17 11l2 2 4-4"/></svg>`
};
---

<section class="py-10 bg-white" id="about">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Top Part: Text & Video -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-24">
      <!-- Left Content -->
      <div class="space-y-8">
        <div>
          <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight leading-tight mb-6">
            About <span class="text-blue-600">Nialabs</span>
          </h2>
          <div class="w-16 h-1.5 bg-blue-600 rounded-full mb-8"></div>
          
          <div class="space-y-6 text-lg text-slate-600 leading-relaxed">
            <p>
              Nialabs is a leading biometric attendance system provider in India, offering AI-powered face and fingerprint recognition devices for schools, colleges, MSMEs, enterprises, and government organizations. Founded in 2021, we’ve built a nationwide presence by simplifying attendance management and workforce tracking for the education and business sectors.
            </p>
            <p>
              Our cloud-based biometric solutions and API integrations help automate attendance tracking, payroll management, and access control —making operations more accurate, secure, and efficient across industries.
            </p>
          </div>
        </div>
        
        <a 
          href="/aboutUs" 
          class="inline-flex items-center px-8 py-4 text-lg font-bold text-white bg-blue-600 rounded-2xl hover:bg-blue-700 shadow-xl shadow-blue-500/20 transition-all duration-300 transform hover:scale-[1.02] hover:-translate-y-1"
        >
          View More
          <svg xmlns="http://www.w3.org/2000/svg" class="ml-2 h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
      </div>

      <!-- Right Video -->
      <div class="relative group">
        <div class="absolute -inset-4 bg-blue-500/5 rounded-[40px] blur-2xl group-hover:bg-blue-500/10 transition-all duration-500"></div>
        <div class="relative rounded-[32px] overflow-hidden shadow-2xl border border-slate-100 bg-white aspect-video flex items-center justify-center">
          <video 
            class="w-full h-full object-cover"
            autoplay 
            loop 
            muted 
            playsinline
          >
            <source src="/mainImages/Nialabs-biometric.mp4" type="video/mp4" />
            Your browser does not support the video tag.
          </video>
          
          <!-- Overlay decoration -->
          <div class="absolute inset-0 ring-1 ring-inset ring-black/10 pointer-events-none rounded-[32px]"></div>
        </div>
      </div>
    </div>

    <!-- Bottom Part: Stats Grid -->
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-6 md:gap-8">
      {stats.map((stat) => (
        <div class="group p-6 rounded-3xl bg-slate-50/50 border border-slate-100 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-300 flex flex-col items-center text-center">
          <!-- Icon -->
          <div class="mb-5 p-3 rounded-2xl bg-white text-blue-600 shadow-sm group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
            <Fragment set:html={icons[stat.icon]} />
          </div>
          
          <!-- Numbers -->
          <div class="text-2xl md:text-3xl font-extrabold text-slate-900 mb-2 group-hover:text-blue-600 transition-colors">
            {stat.bold}
          </div>
          
          <!-- Label -->
          <p class="text-xs md:text-sm font-medium text-slate-500 leading-tight whitespace-pre-line">
            {stat.text}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
