<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const callBtn = document.getElementById("callBtn");

    if (!callBtn) return;

    callBtn.addEventListener("click", () => {
      window.location.href = "tel:+918069409217";
    });
  });
</script>

<style>
