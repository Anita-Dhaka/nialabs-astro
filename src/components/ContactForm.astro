---
---

<div class="relative group">
  <!-- Interactive background glow -->
  <div class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-[36px] blur opacity-20 group-hover:opacity-40 transition duration-1000 group-hover:duration-200"></div>
  
  <div class="relative bg-white rounded-[32px] p-8 md:p-10 shadow-2xl shadow-slate-200/60 border border-slate-100">
    <div class="mb-10">
      <h2 class="text-3xl font-extrabold text-slate-900 mb-4">Please drop us a message</h2>
      <p class="text-slate-600">And we'll get back to you soon.</p>
    </div>

    <form id="contactForm" class="space-y-6">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="yourName" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Name</label>
          <input 
            type="text" 
            id="yourName" 
            name="yourName" 
            placeholder="Your Name" 
            class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
            required
          />
        </div>
        <div>
          <label for="companyName" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Organisation</label>
          <input 
            type="text" 
            id="companyName" 
            name="companyName" 
            placeholder="Organisation's Name" 
            class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
            required
          />
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div>
          <label for="email" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Email ID</label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            placeholder="Eg: yourname@example.com" 
            class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
            required
          />
        </div>
        <div>
          <label for="contactNumber" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Phone/ Mobile</label>
          <input 
            type="tel" 
            id="contactNumber" 
            name="contactNumber" 
            placeholder="Contact Info" 
            class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
            required
          />
        </div>
      </div>

      <div>
        <label for="companyType" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Company Type</label>
        <div class="relative">
          <select 
            id="companyType" 
            name="companyType" 
            class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none font-medium pr-12"
            required
          >
            <option value="General Enquiry">General Enquiry</option>
            <option value="Partnership">Partnership</option>
            <option value="Support">Support</option>
          </select>
          <div class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-400">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
          </div>
        </div>
      </div>

      <div>
        <label for="additionalMessage" class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider">Additional Message</label>
        <textarea 
          id="additionalMessage" 
          name="additionalMessage" 
          rows="4" 
          placeholder="Leave a Message or Comment" 
          class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-none font-medium"
        ></textarea>
      </div>

      <div class="flex items-start gap-3">
        <input type="checkbox" id="privacy" class="mt-1 w-5 h-5 rounded border-slate-300 text-blue-600 focus:ring-blue-500 cursor-pointer" required />
        <label for="privacy" class="text-sm text-slate-500 leading-snug cursor-pointer select-none">
          I agree to the <a href="/privacy-policy" class="text-blue-600 hover:underline font-bold">Privacy Policy</a>. Your information will only be used to contact you.
        </label>
      </div>

      <button 
        type="submit" 
        id="submitBtn"
        class="w-full py-5 bg-[#2067e2] hover:bg-blue-700 text-white font-extrabold text-lg rounded-2xl shadow-xl shadow-blue-500/25 transform transition-all active:scale-[0.98] flex items-center justify-center gap-3 group/btn"
      >
        <span id="btnText">Get in Touch</span>
        <svg id="loadingIcon" class="hidden animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
        <svg id="arrowIcon" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 group-hover/btn:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" />
        </svg>
      </button>

      <div id="formStatus" class="hidden p-4 rounded-xl text-center font-bold"></div>
    </form>
  </div>
</div>

<script>
  const form = document.getElementById('contactForm') as HTMLFormElement;
  const submitBtn = document.getElementById('submitBtn') as HTMLButtonElement;
  const btnText = document.getElementById('btnText');
  const arrowIcon = document.getElementById('arrowIcon');
  const loadingIcon = document.getElementById('loadingIcon');
  const formStatus = document.getElementById('formStatus');

  // Extract UTM parameters
  const urlParams = new URLSearchParams(window.location.search);
  const utmParams = {
    utmSource: urlParams.get('utm_source') || '',
    utmTerm: urlParams.get('utm_term') || '',
    utmMedium: urlParams.get('utm_medium') || '',
    utmCampaign: urlParams.get('utm_campaign') || '',
    utmContent: urlParams.get('utm_content') || '',
  };

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Set loading state
    submitBtn.disabled = true;
    btnText!.textContent = 'Sending...';
    arrowIcon?.classList.add('hidden');
    loadingIcon?.classList.remove('hidden');
    formStatus?.classList.add('hidden');

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    const payload = {
      leadListId: "68b53c175188bd06232e87ea",
      name: data.yourName || "",
      email: data.email || "",
      contact1: data.contactNumber || "",
      customFields: [
        { customFieldId: "6839353dbfaf99e09d8c633c", key: "custom_leads_source", value: utmParams.utmSource },
        { customFieldId: "68393882bfaf99e09d8c8a55", key: "utm_term", value: utmParams.utmTerm },
        { customFieldId: "683938a2bfaf99e09d8c8c9e", key: "utm_medium", value: utmParams.utmMedium },
        { customFieldId: "683938b4bfaf99e09d8c8dc9", key: "utm_campaign", value: utmParams.utmCampaign },
        { customFieldId: "683938cdbfaf99e09d8c8e21", key: "utm_content", value: utmParams.utmContent },
        { customFieldId: "68b53c9b5188bd06232e96a9", key: "nialabs_message", value: data.additionalMessage || "" },
        { customFieldId: "68d6212ef0d45f9cd1076150", key: "company_name", value: data.companyName || "" },
        { customFieldId: "68d6213ef0d45f9cd1076223", key: "campany_type", value: data.companyType || "" },
      ],
    };

    try {
      const response = await fetch("https://api.next.coachinglog.in/api/v1/lead/website", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "iid": "6502a77c6d074427b15f5230",
        },
        body: JSON.stringify(payload),
      });

      if (response.ok) {
        // Success feedback
        formStatus!.textContent = "Thanks! We'll respond within 24 hours.";
        formStatus!.className = "p-4 rounded-xl text-center font-bold bg-green-50 text-green-600 block";
        form.reset();
        
        // Custom event for success (could trigger a modal if needed)
        window.dispatchEvent(new CustomEvent('form-success'));
      } else {
        throw new Error('API failed');
      }
    } catch (err) {
      // Error feedback
      formStatus!.textContent = "Submission failed. Please try again later.";
      formStatus!.className = "p-4 rounded-xl text-center font-bold bg-red-50 text-red-600 block";
    } finally {
      // Reset button state
      submitBtn.disabled = false;
      btnText!.textContent = 'Get in Touch';
      arrowIcon?.classList.remove('hidden');
      loadingIcon?.classList.add('hidden');
    }
  });
</script>
