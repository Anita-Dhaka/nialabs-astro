<section
  class="relative pt-10 pb-16 lg:pt-20 lg:pb-16 overflow-hidden bg-slate-900"
>
  <!-- Background Decorations -->
  <div class="absolute inset-0 z-0">
    <div
      class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-600/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4"
    >
    </div>
    <div
      class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-600/10 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4"
    >
    </div>
    <div
      class="absolute inset-0 bg-[url('/mainImages/grid.svg')] bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] opacity-20"
    >
    </div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
      <!-- Content -->
      <div class="max-w-2xl">
        <div
          class="inline-flex items-center px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-semibold mb-6 animate-fade-in"
        >
          <span class="relative flex h-2 w-2 mr-3">
            <span
              class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"
            ></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"
            ></span>
          </span>
          Excellence in Biometric Technology
        </div>

        <h1
          class="text-3xl md:text-5xl font-extrabold text-white tracking-tight leading-[1.1] mb-6 animate-slide-up"
        >
          <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400"
            >India's Trusted</span
          > Biometric Attendance Partner
        </h1>

        <p
          class="text-base md:text-lg text-slate-400 leading-relaxed mb-4 animate-slide-up animation-delay-200"
        >
          From schools to enterprises, we make attendance management fast,
          accurate, and secure.
        </p>

        <p
          class="text-base md:text-lg text-slate-400 leading-relaxed mb-2 animate-slide-up animation-delay-200"
        >
          <span class="font-bold">Over 1000+ biometrics sold:</span> A proven track record of security and efficiency.
        </p>
        
        <span
          class="text-base md:text-lg text-slate-400 leading-relaxed animate-slide-up animation-delay-200"
        >
          <span class="font-bold">Empowering 250+ School Bus Fleets: </span>with advanced safety and attendance tracking.
        </p>

        <div class="flex mt-8 flex-wrap gap-4 animate-slide-up animation-delay-400">
          <a
            href="#story"
            class="px-8 py-4 bg-blue-600 hover:bg-blue-700 text-white font-bold rounded-2xl transition-all duration-300 transform hover:scale-[1.02] shadow-xl shadow-blue-500/25"
          >
            Get a Custom Quote Today
          </a> 
        </div>
      </div>

      <!-- Right: Contact Form -->
      <div class="relative">
        <div
          class="absolute -inset-4 bg-white/10 rounded-[40px] blur-2xl hidden lg:block"
        >
        </div>
        <div
          class="relative bg-white rounded-[32px] p-8 md:p-10 shadow-2xl border border-white/20"
        >
          <!-- Success Message (Hidden Initial) -->
          <div
            id="landing-success"
            class="hidden h-full flex flex-col items-center justify-center text-center py-12"
          >
            <div
              class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center text-green-600 mb-6"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="40"
                height="40"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                ><polyline points="20 6 9 17 4 12"></polyline></svg
              >
            </div>
            <h3 class="text-2xl font-bold text-slate-900 mb-2">
              Message Sent!
            </h3>
            <p class="text-slate-500 font-medium mb-8">
              Thank you for your interest. Our executive will contact you
              shortly.
            </p>
            <button
              id="landing-reset"
              class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-900 font-bold rounded-xl transition-colors"
            >
              Send Another Message
            </button>
          </div>

          <!-- Form -->
          <form id="landing-form" class="space-y-5">
            <div class="flex flex-col gap-1.5 text-left">
              <label
                for="landing-name"
                class="text-slate-700 text-sm font-bold uppercase tracking-wider"
                >Full Name <span class="text-red-500">*</span></label
              >
              <input
                type="text"
                id="landing-name"
                name="name"
                placeholder="Enter Your Name"
                required
                class="w-full px-5 py-3 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
              />
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              <div class="flex flex-col gap-1.5 text-left">
                <label
                  for="landing-email"
                  class="text-slate-700 text-sm font-bold uppercase tracking-wider"
                  >Email ID <span class="text-red-500">*</span></label
                >
                <input
                  type="email"
                  id="landing-email"
                  name="email"
                  placeholder="Enter Your Email"
                  required
                  class="w-full px-5 py-3 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
                />
                <span
                  id="landing-email-error"
                  class="text-red-500 text-xs hidden mt-1"
                  >Please enter a valid email address.</span
                >
              </div>

              <div class="flex flex-col gap-1.5 text-left">
                <label
                  for="landing-contact"
                  class="text-slate-700 text-sm font-bold uppercase tracking-wider"
                  >Contact No. <span class="text-red-500">*</span></label
                >
                <input
                  type="tel"
                  id="landing-contact"
                  name="contact"
                  placeholder="Enter Your Contact No."
                  required
                  pattern="[6-9][0-9]{9}"
                  class="w-full px-5 py-3 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
                />
                <span
                  id="landing-contact-error"
                  class="text-red-500 text-xs hidden mt-1"
                  >Enter a valid 10-digit Indian mobile number.</span
                >
              </div>
            </div>

            <div class="flex flex-col gap-1.5 text-left">
              <label
                for="landing-business"
                class="text-slate-700 text-sm font-bold uppercase tracking-wider"
                >Business/Institute Name <span class="text-red-500">*</span></label
              >
              <input
                type="text"
                id="landing-business"
                name="name"
                placeholder="Enter Business"
                required
                class="w-full px-5 py-3 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
              />
            </div>

            <div class="flex flex-col gap-1.5 text-left">
              <label
                for="landing-message"
                class="text-slate-700 text-sm font-bold uppercase tracking-wider"
                >Message <span class="text-red-500">*</span></label
              >
              <textarea
                id="landing-message"
                name="message"
                placeholder="Enter Your Message"
                required
                rows="3"
                class="w-full px-5 py-3 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all resize-none"
              ></textarea>
            </div>

            <button
              id="landing-submit"
              type="submit"
              class="w-full px-8 py-3 bg-[#2A6DE4] hover:bg-blue-700 text-white font-extrabold rounded-2xl transition-all duration-300 transform hover:scale-[1.01] shadow-xl shadow-blue-500/25 flex items-center justify-center gap-3 mt-4"
            >
              <span id="landing-btn-text">Send Enquiry</span>
              <svg
                id="landing-spinner"
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="hidden animate-spin"
                ><path d="M21 12a9 9 0 1 1-6.219-8.56"></path></svg
              >
            </button>
          </form>

          <!-- Toast Notification -->
          <div
            id="landing-toast"
            class="absolute -top-16 left-1/2 min-w-max -translate-x-1/2 z-50 hidden transition-all duration-300"
          >
            <div
              class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-white text-sm font-semibold"
              id="landing-toast-inner"
            >
              <svg
                id="landing-toast-icon"
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="3"
                stroke-linecap="round"
                stroke-linejoin="round"></svg>
              <span id="landing-toast-msg"></span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- Toast Notification -->
<div
  id="home-toast"
  class="absolute -top-16 left-1/2 min-w-max -translate-x-1/2 z-50 hidden transition-all duration-300"
>
  <div
    class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-white text-sm font-semibold"
    id="home-toast-inner"
  >
    <svg
      id="home-toast-icon"
      xmlns="http://www.w3.org/2000/svg"
      width="18"
      height="18"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="3"
      stroke-linecap="round"
      stroke-linejoin="round"></svg>
    <span id="home-toast-msg"></span>
  </div>
</div>

<script>
  const form = document.getElementById("landing-form") as HTMLFormElement;
  const successDiv = document.getElementById("landing-success") as HTMLElement;
  const resetBtn = document.getElementById(
    "landing-reset",
  ) as HTMLButtonElement;
  const submitBtn = document.getElementById(
    "landing-submit",
  ) as HTMLButtonElement;
  const btnText = document.getElementById("landing-btn-text") as HTMLElement;
  const btnSpinner = document.getElementById("landing-spinner") as HTMLElement;
  const toast = document.getElementById("landing-toast") as HTMLElement;
  const toastInner = document.getElementById(
    "landing-toast-inner",
  ) as HTMLElement;
  const toastMsg = document.getElementById("landing-toast-msg") as HTMLElement;
  const toastIcon = document.getElementById(
    "landing-toast-icon",
  ) as HTMLElement;
  const emailError = document.getElementById(
    "landing-email-error",
  ) as HTMLElement;
  const contactError = document.getElementById(
    "landing-contact-error",
  ) as HTMLElement;

  function showHomeToast(type: "success" | "error", message: string) {
    toastInner.className = `flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-white text-sm font-semibold ${type === "success" ? "bg-green-600" : "bg-red-600"}`;
    toastIcon.innerHTML =
      type === "success"
        ? '<polyline points="20 6 9 17 4 12"/>'
        : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
    toastMsg.textContent = message;

    toast.classList.remove("hidden", "-translate-y-4", "opacity-0");
    toast.classList.add("translate-y-0", "opacity-100");

    setTimeout(() => {
      toast.classList.remove("translate-y-0", "opacity-100");
      toast.classList.add("-translate-y-4", "opacity-0");
      setTimeout(() => toast.classList.add("hidden"), 300);
    }, 3000);
  }

  function setHomeLoading(loading: boolean) {
    submitBtn.disabled = loading;
    btnText.textContent = loading ? "Sending..." : "Send Enquiry";
    btnSpinner.classList.toggle("hidden", !loading);
  }

  function validateHomeEmail(email: string): boolean {
    return (
      /^\w+([.-]?\w+)*@\w+([.-]?\w+)*(\.\w{2,3})+$/.test(email) &&
      email.length <= 50
    );
  }

  function validateHomeContact(contact: string): boolean {
    return /^[6-9][0-9]{9}$/.test(contact);
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    const nameInput = document.getElementById(
      "landing-name",
    ) as HTMLInputElement;
    const emailInput = document.getElementById(
      "landing-email",
    ) as HTMLInputElement;
    const contactInput = document.getElementById(
      "landing-contact",
    ) as HTMLInputElement;
    const businessInput = document.getElementById(
      "landing-business",
    ) as HTMLInputElement;
    const messageInput = document.getElementById(
      "landing-message",
    ) as HTMLTextAreaElement;

    const name = nameInput.value.trim();
    const email = emailInput.value.trim();
    const contact = contactInput.value.trim();
    const business = businessInput.value.trim();
    const message = messageInput.value.trim();

    // Validate
    let valid = true;
    if (!validateHomeEmail(email)) {
      emailError.classList.remove("hidden");
      valid = false;
    } else {
      emailError.classList.add("hidden");
    }
    if (!validateHomeContact(contact)) {
      contactError.classList.remove("hidden");
      valid = false;
    } else {
      contactError.classList.add("hidden");
    }
    if (!name || !message || !business) {
      valid = false;
    }
    if (!valid) return;

    setHomeLoading(true);

    const payload = {
      leadListId: "68b53c175188bd06232e87ea",
      name, 
      email,
      contact1: contact,
      companyName: business,
      customFields: [
        {
          customFieldId: "68b53c9b5188bd06232e96a9",
          key: "nialabs_message",
          value: message,
        },
      ],
    };

    try {
      const response = await fetch(
        "https://api.next.coachinglog.in/api/v1/lead/website",
        {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
            iid: "6502a77c6d074427b15f5230",
          },
          body: JSON.stringify(payload),
        },
      );

      if (response.ok) {
        showHomeToast("success", "Enquiry submitted successfully");
        form.classList.add("hidden");
        successDiv.classList.remove("hidden");
      } else {
        throw new Error("API request failed");
      }
    } catch {
      showHomeToast("error", "Could not submit enquiry. Please try again.");
    } finally {
      setHomeLoading(false);
    }
  });

  resetBtn?.addEventListener("click", () => {
    form.reset();
    form.classList.remove("hidden");
    successDiv.classList.add("hidden");
  });
</script>
