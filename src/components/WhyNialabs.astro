---
const points = [
  {
    icon: "shield",
    head: "AI-Powered Precision & Security",
    desc: "Experience unmatched accuracy and reliability with advanced AI-based facial and fingerprint recognition. Eliminate proxy attendance and unauthorized access while ensuring complete data security.",
    color: "blue"
  },
  {
    icon: "cloud",
    head: "Seamless Cloud & API Integration",
    desc: "Connect your biometric devices effortlessly with School ERP, HRMS, or Payroll systems through our powerful cloud and API integration, enabling real-time data sync and centralized control.",
    color: "indigo"
  },
  {
    icon: "chart",
    head: "Advanced Data Analytics & Insights",
    desc: "Gain actionable insights with real-time analytics dashboards. Track attendance trends, punctuality, absenteeism, and productivity metrics, all from a single interface.",
    color: "teal"
  },
  {
    icon: "trend",
    head: "Scalability & Flexibility",
    desc: "Whether it’s one campus or multiple offices across cities, Nialabs’ cloud-powered platform grows with your organization, ensuring smooth scalability and flexibility.",
    color: "cyan"
  },
  {
    icon: "lock",
    head: "Integrated Access Control Systems",
    desc: "Secure your premises with role-based access permissions and live monitoring. Manage entry points efficiently using AI-enabled facial or fingerprint authentication.",
    color: "violet"
  },
  {
    icon: "support",
    head: "Dedicated Support & After-Sales Service",
    desc: "From installation to maintenance, our expert support team ensures seamless performance, timely updates, and reliable customer service.",
    color: "sky"
  },
];

const icons = {
  shield: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path></svg>`,
  cloud: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19c2.5 0 4.5-2 4.5-4.5 0-2.3-1.7-4.2-3.9-4.5-1-3.6-4.5-6.3-8.6-6.3-3.4 0-6.4 1.8-8 4.6-1.9.4-3.5 2.1-3.5 4.2 0 2.5 2 4.5 4.5 4.5H17.5z"></path><path d="M12 12v9"></path><path d="m9 18 3 3 3-3"></path></svg>`,
  chart: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"></path><path d="M18 17V9"></path><path d="M13 17V5"></path><path d="M8 17v-3"></path></svg>`,
  trend: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17"></polyline><polyline points="16 7 22 7 22 13"></polyline></svg>`,
  lock: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>`,
  support: `<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path><path d="M12 8v4"></path><path d="M12 16h.01"></path></svg>`
};
---

<section class="py-10 bg-white" id="why-nialabs">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-20">
      <h2 class="text-3xl md:text-5xl font-extrabold text-slate-900 tracking-tight">
        Why <span class="text-blue-600">Nialabs?</span>
      </h2>
      <div class="mt-4 flex justify-center">
        <div class="w-16 h-1.5 bg-blue-600 rounded-full"></div>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {points.map((point) => (
        <div class="group p-8 rounded-3xl border border-slate-100 bg-slate-50/30 hover:bg-white hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-300">
          <!-- Icon -->
          <div class={`mb-4 inline-flex p-4 rounded-2xl bg-blue-50 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors duration-300`}>
            <Fragment set:html={icons[point.icon]} />
          </div>

          <!-- Content -->
          <h3 class="text-xl font-bold text-slate-900 mb-4 group-hover:text-blue-600 transition-colors">
            {point.head}
          </h3>
          <p class="text-slate-600 leading-relaxed text-sm lg:text-base">
            {point.desc}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
