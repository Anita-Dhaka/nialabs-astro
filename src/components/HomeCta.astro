---
export interface Props {
    title?: string;
    desc?: string;
}

const {
    title = "Upgrade to a smarter biometric attendance solution today.",
    desc = "Whether you’re managing a school or running a business, Nialabs has the right technology for you."
} = Astro.props;
---

<section class="relative bg-[#2A6DE4] overflow-hidden" id="contact">
    <!-- Decorative background elements -->
    <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-white/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4"></div>
    <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-500/10 rounded-full blur-[80px] translate-y-1/2 -translate-x-1/4"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28 relative z-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
            
            <!-- Left: Content -->
            <div class="max-w-xl">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/10 border border-white/20 text-white text-sm font-semibold mb-6">
                    <span class="w-2 h-2 rounded-full bg-white animate-pulse"></span>
                    Get In Touch
                </div>
                <h2 class="text-3xl md:text-5xl font-extrabold text-white tracking-tight leading-tight mb-6">
                    {title}
                </h2>
                <p class="text-lg md:text-xl text-blue-100 font-medium mb-12 leading-relaxed">
                    {desc}
                </p>
                
                <div class="space-y-6">
                    <div class="flex items-center gap-4 text-white transform transition-transform hover:translate-x-2 duration-300">
                        <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center border border-white/20 text-white shadow-xl">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                        </div>
                        <div>
                            <p class="text-sm text-blue-100 font-semibold mb-1">Call Us Now</p>
                            <p class="font-bold text-white tracking-wide">+91 80694 09217</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-4 text-white transform transition-transform hover:translate-x-2 duration-300">
                        <div class="w-12 h-12 rounded-2xl bg-white/10 flex items-center justify-center border border-white/20 text-white shadow-xl">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                        </div>
                        <div>
                            <p class="text-sm text-blue-100 font-semibold mb-1">Email Support</p>
                            <p class="font-bold text-white tracking-wide">support@nialabs.in</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Contact Form -->
            <div class="relative">
                <div class="absolute -inset-4 bg-white/10 rounded-[40px] blur-2xl hidden lg:block"></div>
                <div class="relative bg-white rounded-[32px] p-8 md:p-10 shadow-2xl border border-white/20">
                    
                    <!-- Success Message (Hidden Initial) -->
                    <div id="home-cta-success" class="hidden h-full flex flex-col items-center justify-center text-center py-12">
                        <div class="w-20 h-20 bg-green-100 rounded-full flex items-center justify-center text-green-600 mb-6">
                            <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                        <h3 class="text-2xl font-bold text-slate-900 mb-2">Message Sent!</h3>
                        <p class="text-slate-500 font-medium mb-8">Thank you for your interest. Our executive will contact you shortly.</p>
                        <button id="home-cta-reset" class="px-6 py-3 bg-slate-100 hover:bg-slate-200 text-slate-900 font-bold rounded-xl transition-colors">
                            Send Another Message
                        </button>
                    </div>

                    <!-- Form -->
                    <form id="home-cta-form" class="space-y-5">
                        <div class="flex flex-col gap-1.5 text-left">
                            <label for="home-cta-name" class="text-slate-700 text-sm font-bold uppercase tracking-wider">Full Name <span class="text-red-500">*</span></label>
                            <input
                                type="text"
                                id="home-cta-name"
                                name="name"
                                placeholder="Enter Your Name"
                                required
                                class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
                            />
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                            <div class="flex flex-col gap-1.5 text-left">
                                <label for="home-cta-email" class="text-slate-700 text-sm font-bold uppercase tracking-wider">Email ID <span class="text-red-500">*</span></label>
                                <input
                                    type="email"
                                    id="home-cta-email"
                                    name="email"
                                    placeholder="Enter Your Email"
                                    required
                                    class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
                                />
                                <span id="home-cta-email-error" class="text-red-500 text-xs hidden mt-1">Please enter a valid email address.</span>
                            </div>

                            <div class="flex flex-col gap-1.5 text-left">
                                <label for="home-cta-contact" class="text-slate-700 text-sm font-bold uppercase tracking-wider">Contact No. <span class="text-red-500">*</span></label>
                                <input
                                    type="tel"
                                    id="home-cta-contact"
                                    name="contact"
                                    placeholder="Enter Your Contact No."
                                    required
                                    pattern="[6-9][0-9]{9}"
                                    class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all"
                                />
                                <span id="home-cta-contact-error" class="text-red-500 text-xs hidden mt-1">Enter a valid 10-digit Indian mobile number.</span>
                            </div>
                        </div>

                        <div class="flex flex-col gap-1.5 text-left">
                            <label for="home-cta-message" class="text-slate-700 text-sm font-bold uppercase tracking-wider">Message <span class="text-red-500">*</span></label>
                            <textarea
                                id="home-cta-message"
                                name="message"
                                placeholder="Enter Your Message"
                                required
                                rows="3"
                                class="w-full px-5 py-4 rounded-2xl bg-slate-50 border border-slate-100 text-slate-900 placeholder-slate-400 text-sm font-medium focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-[#2A6DE4] transition-all resize-none"
                            ></textarea>
                        </div>

                        <button
                            id="home-cta-submit"
                            type="submit"
                            class="w-full px-8 py-4 bg-[#2A6DE4] hover:bg-blue-700 text-white font-extrabold rounded-2xl transition-all duration-300 transform hover:scale-[1.01] shadow-xl shadow-blue-500/25 flex items-center justify-center gap-3 mt-4"
                        >
                            <span id="home-cta-btn-text">Send Enquiry</span>
                            <svg id="home-cta-spinner" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" class="hidden animate-spin"><path d="M21 12a9 9 0 1 1-6.219-8.56"/></svg>
                        </button>
                    </form>

                    <!-- Toast Notification -->
                    <div id="home-cta-toast" class="absolute -top-16 left-1/2 min-w-max -translate-x-1/2 z-50 hidden transition-all duration-300">
                        <div class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-white text-sm font-semibold" id="home-cta-toast-inner">
                            <svg id="home-cta-toast-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></svg>
                            <span id="home-cta-toast-msg"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


                    <!-- Toast Notification -->
                    <div id="home-toast" class="absolute -top-16 left-1/2 min-w-max -translate-x-1/2 z-50 hidden transition-all duration-300">
                        <div class="flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-white text-sm font-semibold" id="home-toast-inner">
                            <svg id="home-toast-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"></svg>
                            <span id="home-toast-msg"></span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    const form = document.getElementById('home-cta-form') as HTMLFormElement;
    const successDiv = document.getElementById('home-cta-success') as HTMLElement;
    const resetBtn = document.getElementById('home-cta-reset') as HTMLButtonElement;
    const submitBtn = document.getElementById('home-cta-submit') as HTMLButtonElement;
    const btnText = document.getElementById('home-cta-btn-text') as HTMLElement;
    const btnSpinner = document.getElementById('home-cta-spinner') as HTMLElement;
    const toast = document.getElementById('home-cta-toast') as HTMLElement;
    const toastInner = document.getElementById('home-cta-toast-inner') as HTMLElement;
    const toastMsg = document.getElementById('home-cta-toast-msg') as HTMLElement;
    const toastIcon = document.getElementById('home-cta-toast-icon') as HTMLElement;
    const emailError = document.getElementById('home-cta-email-error') as HTMLElement;
    const contactError = document.getElementById('home-cta-contact-error') as HTMLElement;

    function showHomeToast(type: 'success' | 'error', message: string) {
        toastInner.className = `flex items-center gap-3 px-5 py-3 rounded-xl shadow-2xl text-white text-sm font-semibold ${type === 'success' ? 'bg-green-600' : 'bg-red-600'}`;
        toastIcon.innerHTML = type === 'success'
            ? '<polyline points="20 6 9 17 4 12"/>'
            : '<line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>';
        toastMsg.textContent = message;
        
        toast.classList.remove('hidden', '-translate-y-4', 'opacity-0');
        toast.classList.add('translate-y-0', 'opacity-100');
        
        setTimeout(() => {
            toast.classList.remove('translate-y-0', 'opacity-100');
            toast.classList.add('-translate-y-4', 'opacity-0');
            setTimeout(() => toast.classList.add('hidden'), 300);
        }, 3000);
    }

    function setHomeLoading(loading: boolean) {
        submitBtn.disabled = loading;
        btnText.textContent = loading ? 'Sending...' : 'Send Enquiry';
        btnSpinner.classList.toggle('hidden', !loading);
    }

    function validateHomeEmail(email: string): boolean {
        return /^\w+([.-]?\w+)*@\w+([.-]?\w+)*(\.\w{2,3})+$/.test(email) && email.length <= 50;
    }

    function validateHomeContact(contact: string): boolean {
        return /^[6-9][0-9]{9}$/.test(contact);
    }

    form?.addEventListener('submit', async (e) => {
        e.preventDefault();

        const nameInput = document.getElementById('home-cta-name') as HTMLInputElement;
        const emailInput = document.getElementById('home-cta-email') as HTMLInputElement;
        const contactInput = document.getElementById('home-cta-contact') as HTMLInputElement;
        const messageInput = document.getElementById('home-cta-message') as HTMLTextAreaElement;

        const name = nameInput.value.trim();
        const email = emailInput.value.trim();
        const contact = contactInput.value.trim();
        const message = messageInput.value.trim();

        // Validate
        let valid = true;
        if (!validateHomeEmail(email)) {
            emailError.classList.remove('hidden');
            valid = false;
        } else {
            emailError.classList.add('hidden');
        }
        if (!validateHomeContact(contact)) {
            contactError.classList.remove('hidden');
            valid = false;
        } else {
            contactError.classList.add('hidden');
        }
        if (!name || !message) {
            valid = false;
        }
        if (!valid) return;

        setHomeLoading(true);

        const payload = {
            leadListId: "68b53c175188bd06232e87ea",
            name,
            email,
            contact1: contact,
            customFields: [
                {
                    customFieldId: "68b53c9b5188bd06232e96a9",
                    key: "nialabs_message",
                    value: message,
                },
            ],
        };

        try {
            const response = await fetch(
                "https://api.next.coachinglog.in/api/v1/lead/website",
                {
                    method: "POST",
                    headers: {
                        "Content-Type": "application/json",
                        iid: "6502a77c6d074427b15f5230",
                    },
                    body: JSON.stringify(payload),
                }
            );

            if (response.ok) {
                showHomeToast('success', 'Enquiry submitted successfully');
                form.classList.add('hidden');
                successDiv.classList.remove('hidden');
            } else {
                throw new Error('API request failed');
            }
        } catch {
            showHomeToast('error', 'Could not submit enquiry. Please try again.');
        } finally {
            setHomeLoading(false);
        }
    });

    resetBtn?.addEventListener('click', () => {
        form.reset();
        form.classList.remove('hidden');
        successDiv.classList.add('hidden');
    });

</script>
