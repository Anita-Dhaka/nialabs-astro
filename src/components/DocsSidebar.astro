---
import { getCollection } from 'astro:content';
import docsMeta from '../content/docs/_meta.json';

const allDocs = await getCollection('docs');
const currentPath = Astro.url.pathname.replace(/\/$/, '');

// Get all doc IDs
const allIds = allDocs.map(d => d.id);
const metaKeys = Object.keys(docsMeta);

// Items defined in meta
const metaItems = metaKeys.map(key => {
  if (key === '---') {
    return { type: 'separator' };
  }
  
  const label = (docsMeta as any)[key];
  const slug = key === 'index' ? '' : key;
  const href = `/docs/${slug}`.replace(/\/$/, '') || '/docs';
  const isActive = currentPath === href;
  
  return {
    label: typeof label === 'string' ? label : label.title || key,
    href,
    isActive,
    slug: key,
    type: 'link'
  };
});

// Items NOT in meta (if any)
const otherIds = allIds.filter(id => !metaKeys.includes(id === '' ? 'index' : id));
const otherItems = otherIds.map(id => {
  const href = `/docs/${id}`.replace(/\/$/, '') || '/docs';
  const isActive = currentPath === href;
  return {
    label: id.charAt(0).toUpperCase() + id.slice(1).replace(/-/g, ' '),
    href,
    isActive,
    slug: id,
    type: 'link'
  };
});

const sidebarItems = [...metaItems, ...otherItems];

---

<aside class="w-64 flex-shrink-0 border-r border-slate-200 h-[calc(100vh-4rem)] sticky top-16 overflow-y-auto bg-white hidden md:block">
  <nav class="p-4 space-y-1">
    <div class="mb-6">
      <h3 class="px-3 text-xs font-semibold text-slate-500 uppercase tracking-wider">
        Documentation
      </h3>
    </div>
    
    <ul class="space-y-1">
      {sidebarItems.map((item) => (
        item.type === 'separator' ? (
          <li class="my-4 border-t border-slate-100"></li>
        ) : (
          <li>
            <a
              href={item.href}
              class={`block px-3 py-2 text-sm font-medium rounded-md transition-colors ${
                item.isActive
                  ? 'bg-blue-50 text-blue-700'
                  : 'text-slate-600 hover:text-slate-900 hover:bg-slate-50'
              }`}
            >
              {item.label}
            </a>
          </li>
        )
      ))}
    </ul>
  </nav>
</aside>

<!-- Mobile Sidebar (Simplified for now) -->
<div class="md:hidden border-b border-slate-200 bg-white sticky top-16 z-10 px-4 py-2">
  <button id="mobile-sidebar-toggle" class="text-sm font-medium text-slate-600 flex items-center">
    <span>Menu</span>
    <svg class="ml-1 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
    </svg>
  </button>
</div>

<script>
  const toggle = document.getElementById('mobile-sidebar-toggle');
  const sidebar = document.querySelector('aside');
  
  if (toggle && sidebar) {
    toggle.addEventListener('click', () => {
      sidebar.classList.toggle('hidden');
      sidebar.classList.toggle('fixed');
      sidebar.classList.toggle('inset-0');
      sidebar.classList.toggle('z-40');
      sidebar.classList.toggle('bg-white');
      sidebar.classList.toggle('pt-20');
    });
  }
</script>
