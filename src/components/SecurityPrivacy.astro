---
interface Props {
  title: string;
  desc: string;
  image: string;
}

const { title, desc, image } = Astro.props;
---

<section class="py-16 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="bg-slate-900 rounded-[48px] overflow-hidden relative shadow-2xl">
      <!-- Decorative background -->
      <div class="absolute inset-0 opacity-20 pointer-events-none">
        <div class="absolute -top-24 -left-24 w-96 h-96 bg-blue-600 rounded-full blur-[100px]"></div>
        <div class="absolute -bottom-24 -right-24 w-96 h-96 bg-indigo-600 rounded-full blur-[100px]"></div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-0 items-stretch">
        <!-- Content Area -->
        <div class="p-8 md:p-16 lg:p-20 relative z-10">
          <div class="flex items-center gap-3 mb-8">
            <div class="p-3 rounded-2xl bg-blue-500/10 border border-blue-500/20 text-blue-400">
               <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
            </div>
            <p class="text-sm font-black text-blue-400 uppercase tracking-widest">Enterprise Grade Security</p>
          </div>
          
          <h2 class="text-3xl md:text-5xl font-black text-white tracking-tight leading-tight mb-8">
            {title}
          </h2>
          
          <p class="text-lg text-slate-300 leading-relaxed font-medium mb-12">
            {desc}
          </p>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="p-6 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
              <h4 class="text-white font-bold mb-2">Encrypted Data</h4>
              <p class="text-slate-400 text-sm">Military-grade AES-256 encryption for all biometric templates.</p>
            </div>
            <div class="p-6 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors">
              <h4 class="text-white font-bold mb-2">Privacy First</h4>
              <p class="text-slate-400 text-sm">Compliant with global data protection rules and consent policies.</p>
            </div>
          </div>
        </div>

        <!-- Image Area -->
        <div class="relative h-64 lg:h-auto min-h-[400px]">
          <img 
            src={image} 
            alt={title} 
            class="absolute inset-0 w-full h-full object-cover grayscale opacity-80 hover:grayscale-0 hover:opacity-100 transition-all duration-1000"
          />
          <div class="absolute inset-0 bg-gradient-to-r lg:bg-gradient-to-l from-transparent via-transparent to-slate-900"></div>
          
          <!-- Badge -->
          <div class="absolute top-8 right-8">
             <div class="px-6 py-4 bg-white/10 backdrop-blur-xl border border-white/20 rounded-2xl text-white text-center">
                <p class="text-2xl font-black">100%</p>
                <p class="text-[10px] uppercase font-bold tracking-widest text-blue-300">Secure Cloud</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
