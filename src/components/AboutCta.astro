---
interface Props {
  title?: string;
  desc?: string;
}

const {
  title = "Smarter Attendance <br class=\"hidden md:block\"/> Starts Here",
  desc = "From classrooms to boardrooms, Nialabs makes attendance and access control simple, reliable, and future-ready. Take the first step toward efficiency today."
} = Astro.props;
---

<section class="py-10 bg-white">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="relative rounded-[40px] bg-[#2A6DE4] p-8 md:p-16 overflow-hidden shadow-2xl shadow-blue-500/20">
      <!-- Decorative background elements -->
      <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/4"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-500/10 rounded-full blur-[80px] translate-y-1/2 -translate-x-1/4"></div>
      
      <div class="relative z-10 max-w-3xl">
        <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight" set:html={title}></h2>
        {desc && (
          <p class="text-lg md:text-xl text-blue-100 mb-10 leading-relaxed" set:html={desc}></p>
        )}
        
        <div class="flex flex-wrap gap-4">
          <a 
            href="/contactUs" 
            class="open-contact-modal-btn cursor-pointer px-8 py-4 bg-white text-blue-600 font-extrabold rounded-2xl hover:bg-slate-50 transition-all duration-300 transform hover:scale-[1.02] active:scale-95 shadow-xl"
          >
            Talk to Our Experts
          </a>
        </div>
      </div>

      <!-- Optional: Floating visual elements -->
      <div class="absolute right-0 bottom-0 hidden lg:block opacity-20 pointer-events-none">
        <svg width="400" height="400" viewBox="0 0 400 400" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="200" cy="200" r="150" stroke="white" stroke-width="2" stroke-dasharray="10 10"/>
          <circle cx="200" cy="200" r="100" stroke="white" stroke-width="4"/>
          <path d="M200 100V300M100 200H300" stroke="white" stroke-width="2"/>
        </svg>
      </div>
    </div>
  </div>
</section>
