---
const ProductData = [
  {
    modalName: "AI10",
    ProductName: "Smart Bus Attendance System with AI Face Recognition & GPS",
    Image: "/product/ai10/235.webp",
    routeName: "N-AI10-bus-attendence",
  },
  {
    modalName: "AI09",
    ProductName: "Dynamic Face Recognition Terminal",
    Image: "/product/ai09/239.webp",
    routeName: "N-AI09-face-attendence",
  },
  {
    modalName: "AI08",
    ProductName: "Dynamic Face Recognition Terminal with 4G Sim",
    Image: "/product/ai08/229.webp",
    routeName: "N-AI08-face-recognition",
  },
  {
    modalName: "N-AI07",
    ProductName: "Face, Fingerprint Time Attendance and Access Control System",
    Image: "/product/ai07/218.webp",
    routeName: "N-AI07-face-fingerprint",
  },
  {
    modalName: "N-AI06",
    ProductName: "Face Time Attendance & Access Control Reader",
    Image: "/product/ai06/223.webp",
    routeName: "N-AI06-face-recognition",
  },
  {
    modalName: "AI05",
    ProductName: "Face Recognition Time Attendance & Access Control System",
    Image: "/product/ai04/243.webp",
    routeName: "AI05-face-recognition",
  },
  {
    modalName: "AI04",
    ProductName: "Face Recognition Biometric Terminal",
    Image: "/product/ai04/246.webp",
    routeName: "AI04-cloud-ai-powered",
  },
];
---

<section class="py-10 bg-slate-50" id="products">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight">
        Get the Best of <span class="text-blue-600">Biometric Devices</span> <br class="hidden md:block" />
        with Nialabs
      </h2>
      <div class="mt-4 flex justify-center">
        <div class="w-16 h-1.5 bg-blue-600 rounded-full"></div>
      </div>
    </div>

    <!-- Products Grid -->
    <!-- Mobile: Standard Grid | Desktop: Custom 2-3-2 Layout -->
    <div class="product-grid">
      {ProductData.map((product, index) => (
        <a 
          href={`/products/biometric-attendance-machine/${product.routeName}`}
          class={`product-card group relative bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-500 flex flex-col items-center text-center overflow-hidden item-${index}`}
        >
          <!-- Background Glow on Hover -->
          <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <!-- Product Image Container -->
          <div class="relative w-full aspect-square mb-4 flex items-center justify-center p-2">
            <img 
              src={product.Image} 
              alt={product.ProductName} 
              class="max-w-full max-h-full object-contain transform group-hover:scale-110 transition-transform duration-700"
              loading="lazy"
            />
          </div>

          <!-- Product Info -->
          <div class="relative z-10">
            <span class="inline-block px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold uppercase tracking-wider mb-3">
              {product.modalName}
            </span>
            <h3 class="text-lg font-bold text-slate-800 leading-snug group-hover:text-blue-600 transition-colors duration-300">
              {product.ProductName}
            </h3>
            
            <!-- CTA Arrow -->
            <div class="mt-6 flex items-center justify-center gap-2 text-blue-600 font-semibold text-sm opacity-0 group-hover:opacity-100 transform translate-y-2 group-hover:translate-y-0 transition-all duration-300">
              View Details
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  /* Mobile / Tablet: Standard Grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Tablet & Desktop: Custom 2-3-2 Grid */
  @media (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 1.5rem;
    }

    /* Row 1: 2 items centered (cols 2-3 and 4-5) */
    .item-0 { grid-column: 2 / span 2; }
    .item-1 { grid-column: 4 / span 2; }

    /* Row 2: 3 items (cols 1-2, 3-4, 5-6) */
    .item-2 { grid-column: 1 / span 2; }
    .item-3 { grid-column: 3 / span 2; }
    .item-4 { grid-column: 5 / span 2; }

    /* Row 3: 2 items centered (cols 2-3 and 4-5) */
    .item-5 { grid-column: 2 / span 2; }
    .item-6 { grid-column: 4 / span 2; }
    
    /* Ensure cards keep their proportions */
    .product-card {
      min-height: 380px;
      padding: 1.25rem;
    }

    .product-card h3 {
      font-size: 1rem;
    }
  }

  /* Desktop Spacing (1024px and up) */
  @media (min-width: 1024px) {
    .product-grid {
      gap: 2rem;
    }
    .product-card {
      min-height: 400px;
      padding: 1.5rem;
    }
    .product-card h3 {
      font-size: 1.125rem;
    }
  }

  /* Extra Large Desktop Spacing */
  @media (min-width: 1280px) {
    .product-grid {
      gap: 3rem;
    }
  }
</style>
