---
const ProductData = [
  {
    modalName: "AI10",
    ProductName: "Smart Bus Attendance System with AI Face Recognition & GPS",
    Image: "/product/ai10/235.webp",
    routeName: "N-AI10-bus-attendence",
  },
  {
    modalName: "AI09",
    ProductName: "Dynamic Face Recognition Terminal",
    Image: "/product/ai09/239.webp",
    routeName: "N-AI09-face-attendence",
  },
  {
    modalName: "AI08",
    ProductName: "Dynamic Face Recognition Terminal with 4G Sim",
    Image: "/product/ai08/229.webp",
    routeName: "N-AI08-face-recognition",
  },
  {
    modalName: "N-AI07",
    ProductName: "Face, Fingerprint Time Attendance and Access Control System",
    Image: "/product/ai07/218.webp",
    routeName: "N-AI07-face-fingerprint",
  },
  {
    modalName: "N-AI06",
    ProductName: "Face Time Attendance & Access Control Reader",
    Image: "/product/ai06/223.webp",
    routeName: "N-AI06-face-recognition",
  },
  {
    modalName: "AI05",
    ProductName: "Face Recognition Time Attendance & Access Control System",
    Image: "/product/ai04/243.webp",
    routeName: "AI05-face-recognition",
  },
  {
    modalName: "AI04",
    ProductName: "Face Recognition Biometric Terminal",
    Image: "/product/ai04/246.webp",
    routeName: "AI04-cloud-ai-powered",
  },
];
---

<section class="py-10 bg-slate-50" id="products">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="text-2xl md:text-4xl font-extrabold text-slate-900 tracking-tight leading-tight">
        Get the Best of <span class="text-blue-600">Biometric Devices</span> <br class="hidden md:block" />
        with Nialabs
      </h2>
      <div class="mt-4 flex justify-center">
        <div class="w-16 h-1.5 bg-blue-600 rounded-full"></div>
      </div>
    </div>

    <!-- Carousel Wrapper -->
    <div class="relative">

      <!-- Left Button -->
      <button id="scrollLeftBtn"
        class="hidden md:flex items-center justify-center absolute left-0 top-1/2 -translate-y-1/2 z-10 bg-slate-300 backdrop-blur shadow-lg p-3 rounded-full hover:scale-110 transition">
        ←
      </button>

      <!-- Scroll Container -->
      <div id="carousel"
        class="flex gap-6 overflow-x-auto scroll-smooth snap-x snap-mandatory pb-4 scrollbar-hide">

        {[...ProductData, ...ProductData, ...ProductData].map((product) => (
          <a 
            href={`/products/biometric-attendance-machine/${product.routeName}`}
            class="group relative min-w-[260px] sm:min-w-[280px] lg:min-w-[350px] snap-start bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-500 flex flex-col items-center text-center overflow-hidden"
          >

            <!-- Background Glow -->
            <div class="absolute inset-0 bg-gradient-to-br from-blue-50/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

            <!-- Image -->
            <div class="relative w-full aspect-square mb-4 flex items-center justify-center p-2">
              <img 
                src={product.Image} 
                alt={product.ProductName} 
                class="max-w-full max-h-full object-contain transform group-hover:scale-110 transition-transform duration-700"
                loading="lazy"
              />
            </div>

            <!-- Info -->
            <div class="relative z-10">
              <span class="inline-block px-3 py-1 rounded-full bg-blue-50 text-blue-600 text-xs font-bold uppercase tracking-wider mb-3">
                {product.modalName}
              </span>

              <h3 class="text-lg font-bold text-slate-800 leading-snug group-hover:text-blue-600 transition-colors duration-300">
                {product.ProductName}
              </h3>

              <div class="mt-6 text-blue-600 font-semibold text-sm opacity-0 group-hover:opacity-100 transition-all duration-300">
                View Details →
              </div>
            </div>
          </a>
        ))}

      </div>

      <!-- Right Button -->
      <button id="scrollRightBtn"
        class="hidden md:flex items-center justify-center absolute right-0 top-1/2 -translate-y-1/2 z-10 bg-slate-300 backdrop-blur shadow-lg p-3 rounded-full hover:scale-110 transition">
        →
      </button>
    </div>
  </div>
</section>

<style>
  /* Mobile / Tablet: Standard Grid */
  .product-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .product-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* Tablet & Desktop: Custom 2-3-2 Grid */
  @media (min-width: 768px) {
    .product-grid {
      grid-template-columns: repeat(6, 1fr);
      gap: 1.5rem;
    }

    /* Row 1: 2 items centered (cols 2-3 and 4-5) */
    .item-0 { grid-column: 2 / span 2; }
    .item-1 { grid-column: 4 / span 2; }

    /* Row 2: 3 items (cols 1-2, 3-4, 5-6) */
    .item-2 { grid-column: 1 / span 2; }
    .item-3 { grid-column: 3 / span 2; }
    .item-4 { grid-column: 5 / span 2; }

    /* Row 3: 2 items centered (cols 2-3 and 4-5) */
    .item-5 { grid-column: 2 / span 2; }
    .item-6 { grid-column: 4 / span 2; }
    
    /* Ensure cards keep their proportions */
    .product-card {
      min-height: 380px;
      padding: 1.25rem;
    }

    .product-card h3 {
      font-size: 1rem;
    }
  }

  /* Desktop Spacing (1024px and up) */
  @media (min-width: 1024px) {
    .product-grid {
      gap: 2rem;
    }
    .product-card {
      min-height: 400px;
      padding: 1.5rem;
    }
    .product-card h3 {
      font-size: 1.125rem;
    }
  }

  /* Extra Large Desktop Spacing */
  @media (min-width: 1280px) {
    .product-grid {
      gap: 3rem;
    }
  }
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
</style>
<script is:inline>
  document.addEventListener("DOMContentLoaded", () => {
    const container = document.getElementById('carousel');
    const leftBtn = document.getElementById('scrollLeftBtn');
    const rightBtn = document.getElementById('scrollRightBtn');

    const scrollAmount = 320;

    // Manual buttons
    leftBtn?.addEventListener('click', () => {
      container?.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    rightBtn?.addEventListener('click', () => {
      container?.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });

    // ✅ AUTO SCROLL
    let autoScroll = setInterval(() => {
      if (!container) return;

      const maxScroll = container.scrollWidth / 3; // 1 set width

      // When reaching near end of 2nd set → jump back silently
      if (container.scrollLeft >= maxScroll * 2) {
        container.scrollLeft = maxScroll; // no animation → seamless
      } else {
        container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      }

    }, 3000);
    // ✅ Pause on hover (VERY IMPORTANT UX)
    container?.addEventListener("mouseenter", () => {
      clearInterval(autoScroll);
    });

    container?.addEventListener("mouseleave", () => {
      autoScroll = setInterval(() => {
        if (container.scrollLeft + container.clientWidth >= container.scrollWidth - 10) {
          container.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          container.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        }
      }, 3000);
    });
  });
</script>