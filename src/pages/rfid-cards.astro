---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ProductHero from '../components/ProductHero.astro';
import ProductFeatures from '../components/ProductFeatures.astro';
import ProductIndustries from '../components/ProductIndustries.astro';
import Footer from '../components/Footer.astro';
import Faq from '../components/Faq.astro';
import WhyChooseNialabs from '../components/WhyChooseNialabs.astro';

const headerData = {
    title: "RFID Card by Nialabs",
    desc: "RFID cards that power attendance, access control & cashless systems.",
    image: "/headerImages/cards/RFID-card.webp",
};

const whatData = {
    title: "What is an RFID card?",
    desc: [
        "An RFID (Radio Frequency Identification) card is a contactless smart card embedded with a microchip and an antenna. The embedded microchip stores data and supports encryption. The RFID card communicates with reader devices and performs functions such as access control, identity verification, cashless payments, inventory management, etc.",
        "Unlike barcodes, RFID cards do not need to be seen to be read. They can be read through wallets, pockets, or purses."
    ],
};

const cardComponents = [
    { label: "Chip/IC", value: "Stores a unique ID and sometimes additional data." },
    { label: "Antenna", value: "Copper/aluminium coil that captures radio signals and sends data back." },
    { label: "Substrate & PVC body", value: "The physical card body that you can print school/office branding on." }
];

const howItWorks = [
    "The RFID reader emits radio waves.",
    "The RFID card enters the reader’s range.",
    "The card’s chip is powered (passive cards).",
    "The card transmits its unique ID.",
    "The system verifies and records the data."
];

const typesOfCards = [
    { 
        title: "Passive Cards", 
        desc: "No battery. Powered by the reader. Cheaper, thinner, lasts forever. (99% of cards are this)." 
    },
    { 
        title: "Active Cards", 
        desc: "Have a battery. Transmits signal over 100m. Used for tracking people in dangerous zones (e.g., oil rigs)." 
    },
    { 
        title: "Read-Only (RO)", 
        desc: "Data is written once by the manufacturer (like a unique ID number) and cannot be changed." 
    },
    { 
        title: "Read-Write (RW)", 
        desc: "You can rewrite data on the card (e.g., updating a user's access level or subway balance)." 
    }
];

const keyFeatures = {
    title: "Functions & Features of RFID Cards",
    points: [
        { text: "Identification and inventory: Uniquely identifies a person/asset in milliseconds.", icon: "gps" },
        { text: "Access control: Opens doors, gates, and boom barriers when authorised.", icon: "integration" },
        { text: "Attendance logging: Captures IN/OUT time when tapped on attendance machines.", icon: "ai" },
        { text: "Cashless payments: Stores wallet balance or links to account for canteen, vending, and events.", icon: "cloud" },
    ]
};

const applications = {
    title: "Applications of RFID Cards",
    items: [
        {
            title: "Schools & Colleges",
            text: "Student ID + smart attendance at the gate/class. Library automation, cashless canteen, and bus tracking.",
            image: "/headerImages/industries/school.webp"
        },
        {
            title: "Corporate Offices & IT Parks",
            text: "Employee ID, access to different zones, and visitor badges. Attendance integration with HRMS/payroll.",
            image: "/headerImages/industries/enterprise.webp"
        },
        {
            title: "Manufacturing & Warehouses",
            text: "Worker attendance, restricted area access. Asset and inventory tracking with RFID cards/tags.",
            image: "/headerImages/industries/warehouse.webp"
        },
        {
            title: "Residential & Parking",
            text: "Vehicle RFID cards/stickers for gate automation. Clubhouse, gym, and swimming pool access.",
            image: "/headerImages/industries/complex.webp"
        }
    ]
};

const whyChooseData = {
    title: "Why Choose Nialabs RFID Cards?",
    desc: [
        "Premium quality chips",
        "Custom printing & branding",
        "Compatible with all Nialabs readers",
        "Bulk supply across India",
        "Affordable pricing"
    ]
};

const faqData = [
  {
    question: " What is an RFID card used for?",
    solution:
      "An RFID card is used for contactless identification and authentication in systems like attendance tracking, access control, student ID management, asset tracking, and cashless transactions.",
  },
  {
    question: "Which RFID card is best for attendance systems?",
    solution:
      "High Frequency (13.56 MHz) RFID cards, such as MIFARE Classic or DESFire, are best for attendance systems due to their speed, accuracy, and compatibility with most readers.",
  },
  {
    question: "Can RFID cards work without an internet connection?",
    solution:
      "Yes. RFID cards can record attendance or access offline, and the data automatically syncs to the cloud once the internet is available.",
  },
  {
    question: "Are RFID cards safe and secure?",
    solution:
      "Yes. RFID cards use unique encrypted IDs. Advanced cards like DESFire offer high-level security and cannot be easily cloned or duplicated.",
  },
  {
    question: "What is the lifespan of an RFID card?",
    solution:
      "A good-quality RFID card typically lasts 5 to 10 years, depending on usage and handling conditions.",
  },
  {
    question: "Can RFID cards be customized with a logo and a photo?",
    solution:
      "Absolutely. Nialabs offers custom printing, including logo, employee/student photo, name, ID number, barcode, and branding.",
  },
  {
    question: "What is the difference between RFID and NFC cards?",
    solution:
      "NFC cards are a subset of RFID cards that operate at 13.56 MHz and can communicate with smartphones, while RFID cards also work with dedicated RFID readers.",
  },
  {
    question: "Can one RFID card be used for multiple purposes?",
    solution:
      "Yes. A single RFID card can be used for attendance, access control, library management, and cafeteria payments, depending on system configuration.",
  },
  {
    question: "Do RFID cards get damaged easily?",
    solution:
      "No. RFID cards are highly durable, waterproof, and resistant to dust, making them suitable for daily institutional use.",
  },
  {
    question: "Why should I buy RFID cards from Nialabs?",
    solution:
      "Nialabs provides premium-quality RFID cards, custom printing, compatibility with biometric systems, competitive pricing, pan-India delivery, and expert technical support.",
  },
];

const title = "RFID Cards for Attendance & Access Control | Nialabs";
const description = "Get high-quality RFID cards for attendance tracking, access control, and secure identification. Durable, customizable, and ideal for schools, offices, and enterprises.";
---

<Layout title={title} description={description}>
    <Navbar />
    <main class="bg-white">
        <ProductHero 
            title={headerData.title}
            desc={headerData.desc}
            image={headerData.image}
            badge="Contactless Identification"
        />

        <!-- What is Section -->
        <section class="py-16 bg-[#f8fafc] relative overflow-hidden" id="explore">
            <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-blue-500/10 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4"></div>
            <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-indigo-500/10 rounded-full blur-[120px] translate-y-1/2 -translate-x-1/4"></div>

            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-center">
                    <div class="lg:col-span-7 bg-white/60 backdrop-blur-xl rounded-[48px] p-8 md:p-12 lg:p-16 border border-white shadow-2xl shadow-slate-200/50">
                        <div class="flex items-center gap-3 mb-6">
                            <div class="w-10 h-1 bg-[#2067e2] rounded-full"></div>
                            <p class="text-sm font-black text-blue-600 uppercase tracking-widest">About RFID Cards</p>
                        </div>
                        <h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight leading-tight mb-8">
                            {whatData.title}
                        </h2>
                        <div class="space-y-6 text-lg text-slate-600 leading-relaxed font-medium">
                            {whatData.desc.map((paragraph) => (
                                <p>{paragraph}</p>
                            ))}
                        </div>
                        <div class="mt-8 space-y-4">
                            {cardComponents.map((comp) => (
                                <div class="flex items-start gap-4">
                                    <div class="mt-1.5 w-2 h-2 rounded-full bg-blue-600 flex-shrink-0"></div>
                                    <p class="text-slate-700"><strong>{comp.label}:</strong> {comp.value}</p>
                                </div>
                            ))}
                        </div>
                    </div>
                    <div class="lg:col-span-5 relative group mt-8 lg:mt-0">
                        <div class="relative w-full rounded-[48px] overflow-hidden shadow-2xl border border-white transform transition-all duration-700 group-hover:scale-[1.02] bg-white">
                            <img 
                                src="/headerImages/cards/rifdSimple.webp" 
                                alt={whatData.title} 
                                class="w-full h-auto object-contain transform transition-transform duration-1000 group-hover:scale-105"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- How it Works Section -->
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
                    <div>
                        <h2 class="text-3xl font-extrabold text-gray-900 mb-6">How Does an RFID Card Work?</h2>
                        <ul class="space-y-6">
                            {howItWorks.map((step, index) => (
                                <li class="flex items-start">
                                    <div class="flex-none bg-blue-600 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 mt-1">
                                        {index + 1}
                                    </div>
                                    <p class="text-gray-600 text-lg">{step}</p>
                                </li>
                            ))}
                        </ul>
                    </div>
                    <div class="bg-gray-50 p-8 rounded-3xl shadow-lg border border-gray-100">
                        <img src="/headerImages/cards/Working-RFID.webp" alt="How RFID Card Works" class="rounded-2xl w-full h-auto" />
                    </div>
                </div>
            </div>
        </section>

        <!-- Types of Cards -->
        <section class="py-20 bg-gray-50">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-4">Types of RFID Cards</h2>
                    <p class="text-lg text-gray-600 max-w-2xl mx-auto">Different RFID card technologies designed for specific security and range requirements.</p>
                </div>
                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
                    {typesOfCards.map((type) => (
                        <div class="bg-white p-8 rounded-3xl shadow-xl border border-gray-100 hover:scale-[1.02] transition-transform">
                            <h3 class="text-xl font-bold text-gray-900 mb-4">{type.title}</h3>
                            <p class="text-gray-600 leading-relaxed">{type.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
        </section>

        <!-- RFID Comparison Section -->
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="text-center mb-16">
                    <h2 class="text-3xl md:text-5xl font-extrabold text-gray-900 mb-4">RFID Cards vs Other Identification Methods</h2>
                    <p class="text-lg text-gray-600">Understand why RFID is the preferred choice for modern institutions.</p>
                </div>
                <div class="overflow-hidden rounded-3xl border border-gray-200 shadow-xl bg-white">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="bg-slate-900 text-white">
                                <th class="px-6 py-5 font-bold text-lg">Feature</th>
                                <th class="px-6 py-5 font-bold text-lg text-blue-400">RFID Cards</th>
                                <th class="px-6 py-5 font-bold text-lg text-gray-400">Barcode / QR</th>
                                <th class="px-6 py-5 font-bold text-lg text-gray-400">Manual Entry</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            {[
                                { f: "Read Speed", r: "Milliseconds", b: "Seconds", m: "Minutes" },
                                { f: "Line of Sight", r: "Not Required", b: "Required", m: "Required" },
                                { f: "Data Capacity", r: "High (Encrypted)", b: "Low", m: "Minimal" },
                                { f: "Durability", r: "Very High", b: "Low (Paper/Print)", m: "N/A" },
                                { f: "Security", r: "High (Cloning resistant)", b: "Low (Easy to copy)", m: "Low" }
                            ].map((row) => (
                                <tr class="hover:bg-blue-50/30 transition-colors">
                                    <td class="px-6 py-5 font-bold text-gray-700">{row.f}</td>
                                    <td class="px-6 py-5 font-semibold text-blue-600">{row.r}</td>
                                    <td class="px-6 py-5 text-gray-500">{row.b}</td>
                                    <td class="px-6 py-5 text-gray-500">{row.m}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
        </section>

        <!-- Technical Core Section -->
        <section class="py-20 bg-slate-900 text-white overflow-hidden">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
                <div class="absolute top-0 right-0 w-96 h-96 bg-blue-600/20 rounded-full blur-3xl -translate-y-1/2 translate-x-1/2"></div>
                <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
                    <div>
                        <h2 class="text-3xl md:text-5xl font-black mb-8 leading-tight">
                            The Technical Core: <br/> <span class="text-blue-400">Frequency Categories</span>
                        </h2>
                        <div class="space-y-8">
                            {[
                                { 
                                    label: "Low Frequency (LF) - 125 kHz", 
                                    desc: "Short read range (1-2 cm). Used for basic access control and animal tracking. Durable but limited data.",
                                    icon: "M13 10V3L4 14h7v7l9-11h-7z"
                                },
                                { 
                                    label: "High Frequency (HF) - 13.56 MHz", 
                                    desc: "Read range up to 10 cm. Standard for attendance, smart cards (MIFARE), and mobile-linked systems.",
                                    icon: "M12 21a9 9 0 110-18 9 9 0 010 18zm0-15v6m0 4h.01"
                                },
                                { 
                                    label: "Ultra-High Frequency (UHF) - 860-960 MHz", 
                                    desc: "Long read range (3-10m+). Ideal for vehicle tracking, parking, and logistics management.",
                                    icon: "M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                                }
                            ].map((item) => (
                                <div class="flex items-start gap-4 group">
                                    <div class="w-12 h-12 rounded-2xl bg-blue-600/20 flex items-center justify-center text-blue-400 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                                        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d={item.icon}/></svg>
                                    </div>
                                    <div>
                                        <h3 class="text-xl font-bold mb-2">{item.label}</h3>
                                        <p class="text-blue-100/60 leading-relaxed font-medium">{item.desc}</p>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </div>
                    <div class="relative group">
                        <div class="absolute -inset-4 bg-blue-600/20 rounded-[48px] blur-3xl group-hover:opacity-40 transition-opacity"></div>
                        <div class="relative rounded-[48px] overflow-hidden border border-white/10 shadow-3xl bg-slate-800">
                            <img 
                                src="/headerImages/cards/rfidPower.webp" 
                                alt="Technical Frequency Core" 
                                class="w-full h-auto object-cover transform transition-transform duration-1000 group-hover:scale-110"
                            />
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <ProductFeatures 
            title={keyFeatures.title}
            features={keyFeatures.points}
        />

        <ProductIndustries 
            title={applications.title}
            items={applications.items}
        />

        <WhyChooseNialabs 
            title={whyChooseData.title}
            points={whyChooseData.desc}
            image="/headerImages/cards/rfidPower.webp"
        />

        <!-- Call to Action -->
        <section class="py-20 bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
                <div class="relative rounded-[40px] bg-blue-600 p-8 md:p-16 overflow-hidden shadow-2xl shadow-blue-500/20">
                    <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-white/10 rounded-full blur-[100px] -translate-y-1/2 translate-x-1/4"></div>
                    
                    <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
                        <div>
                            <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
                                Looking to Buy RFID Cards <br/> For Your Organization?
                            </h2>
                            <p class="text-lg md:text-xl text-blue-100 mb-8 leading-relaxed">
                                Get expert guidance, best pricing, and fast delivery.
                            </p>
                            <div class="flex flex-wrap gap-4">
                                <a href="/contactUs" class="open-contact-modal-btn cursor-pointer px-8 py-4 bg-white text-blue-600 font-extrabold rounded-2xl hover:bg-slate-50 transition-all duration-300 transform hover:scale-[1.02] active:scale-95 shadow-xl">
                                    Book a Demo
                                </a>
                            </div>
                        </div>
                        <div class="bg-white/10 backdrop-blur-md rounded-3xl p-8 border border-white/20">
                            <ul class="space-y-6">
                                {[
                                    "Premium quality chips",
                                    "Long-lasting & durable",
                                    "Custom logo printing"
                                ].map((point) => (
                                    <li class="flex items-center text-white text-xl font-semibold">
                                        <div class="w-10 h-10 rounded-xl bg-green-400/20 flex items-center justify-center mr-4 text-green-400">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                                        </div>
                                        {point}
                                    </li>
                                ))}
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <Faq 
            faqs={faqData}
            title="Frequently Asked Questions"
        />
    </main>
    <Footer />
</Layout>
