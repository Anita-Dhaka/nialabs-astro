---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import ProductHero from "../components/ProductHero.astro";

const companyType = [
  "Private Limited",
  "Sole Proprietorship",
  "Startup",
  "Others",
];

const partnerType = [
  "Agent",
  "Reseller",
  "Technology Partner",
  "Distributor",
  "Others",
];

const interestedProducts = [
  "Bus Attendance Machine with AI Face Recognition & GPS",
  "AI Face Recognition Attendance & Access Control System",
  "Dynamic Face Recognition Terminal with 4G Sim",
  "Dynamic Face & Fingerprint Recognition Terminal",
  "Dynamic Face Recognition Terminal",
  "Face Recognition Time Attendance & Access Control System",
  "Face Recognition Biometric Terminal – Cloud & AI-Powered Attendance Solution - AI04",
];

const statesOfIndia = [
  "Andhra Pradesh",
  "Arunachal Pradesh",
  "Assam",
  "Bihar",
  "Chhattisgarh",
  "Goa",
  "Gujarat",
  "Haryana",
  "Himachal Pradesh",
  "Jharkhand",
  "Karnataka",
  "Kerala",
  "Madhya Pradesh",
  "Maharashtra",
  "Manipur",
  "Meghalaya",
  "Mizoram",
  "Nagaland",
  "Odisha",
  "Punjab",
  "Rajasthan",
  "Sikkim",
  "Tamil Nadu",
  "Telangana",
  "Tripura",
  "Uttar Pradesh",
  "Uttarakhand",
  "West Bengal",
];
---

<Layout
  title="Become a Partner | Nialabs"
  description="Join Nialabs partner network to grow with India’s leading biometric attendance & access control solutions. Unlock rewards, training & dedicated support."
>
  <Navbar />

  <main class="bg-slate-50 relative min-h-screen">
    <!-- Dark Animated Hero Section -->
    <!-- <section class="relative pt-24 pb-20 lg:pt-36 lg:pb-32 overflow-hidden bg-slate-900 border-b border-slate-800">
      <div class="absolute inset-0 z-0 pointer-events-none">
        <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-blue-600/20 rounded-full blur-[120px] -translate-y-1/2 translate-x-1/4"></div>
        <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-indigo-600/10 rounded-full blur-[100px] translate-y-1/2 -translate-x-1/4"></div>
        <div class="absolute inset-0 bg-[url('/mainImages/grid.svg')] bg-center [mask-image:linear-gradient(180deg,white,rgba(255,255,255,0))] opacity-20"></div>
      </div>

      <div class="relative z-10 max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-blue-500/10 border border-blue-500/20 text-blue-400 text-sm font-semibold mb-8 animate-fade-in">
          <span class="relative flex h-2 w-2 mr-3">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-blue-400 opacity-75"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-blue-500"></span>
          </span>
          Partner Program
        </div>
        
        <h1 class="text-4xl md:text-6xl lg:text-7xl font-extrabold text-white tracking-tight leading-[1.1] mb-6 animate-slide-up animation-delay-100">
          Partner <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-indigo-400 to-blue-400 bg-[length:200%_auto] animate-gradient">On-Boarding</span>
        </h1>
        
        <p class="text-lg md:text-2xl text-slate-400 font-medium leading-relaxed max-w-2xl mx-auto animate-slide-up animation-delay-300">
          Join as a Partner with Nialabs.
        </p>
      </div>
    </section> -->
    <ProductHero
      title="Partner On-Boarding"
      desc="Join as a Partner with Nialabs."
      image="/headerImages/partner.png"
      badge="Centralized Security"
    />

    <div
      class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-20 mt-10 mb-24"
    >
      <!-- Form Container -->
      <div class="relative group">
        <div
          class="absolute -inset-1 bg-gradient-to-r from-blue-600 to-indigo-600 rounded-[36px] blur opacity-20 transition duration-1000"
        >
        </div>
        <div
          class="relative bg-white rounded-[32px] p-8 md:p-12 shadow-2xl shadow-slate-200/60 border border-slate-100"
        >
          <form id="partnerForm" class="space-y-8">
            <!-- Personal Details Section -->
            <div class="space-y-6">
              <h2 class="text-xl font-bold border-b pb-2 text-slate-800">
                Personal Details
              </h2>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label
                    for="yourName"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Your Name <span class="text-red-500">*</span></label
                  >
                  <input
                    type="text"
                    id="yourName"
                    name="yourName"
                    placeholder="Your Name"
                    required
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
                <div>
                  <label
                    for="designation"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Designation <span class="text-red-500">*</span></label
                  >
                  <input
                    type="text"
                    id="designation"
                    name="designation"
                    placeholder="E.g. CEO, Manager"
                    required
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
              </div>
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label
                    for="contactNumber"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Contact Number <span class="text-red-500">*</span></label
                  >
                  <input
                    type="tel"
                    id="contactNumber"
                    name="contactNumber"
                    placeholder="10-digit primary number"
                    required
                    minlength="10"
                    maxlength="15"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
                <div>
                  <label
                    for="whatsappNumber"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >WhatsApp Number</label
                  >
                  <input
                    type="tel"
                    id="whatsappNumber"
                    name="whatsappNumber"
                    placeholder="10-digit number (different from primary)"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
              </div>
              <div>
                <label
                  for="email"
                  class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                  >Email ID</label
                >
                <input
                  type="email"
                  id="email"
                  name="email"
                  placeholder="example@domain.com"
                  class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                />
              </div>
            </div>

            <!-- Company Details Section -->
            <div class="space-y-6 pt-4">
              <h2 class="text-xl font-bold border-b pb-2 text-slate-800">
                Company Details
              </h2>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label
                    for="companyName"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Company Name <span class="text-red-500">*</span></label
                  >
                  <input
                    type="text"
                    id="companyName"
                    name="companyName"
                    placeholder="Your Company Name"
                    required
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
                <div>
                  <label
                    for="companyType"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Company Type</label
                  >
                  <div class="relative">
                    <select
                      id="companyType"
                      name="companyType"
                      class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none font-medium pr-12"
                    >
                      {
                        companyType.map((type) => (
                          <option value={type}>{type}</option>
                        ))
                      }
                    </select>
                    <div
                      class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-400"
                    >
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 9l-7 7-7-7"></path></svg
                      >
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label
                    for="gstNumber"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >GST Number</label
                  >
                  <input
                    type="text"
                    id="gstNumber"
                    name="gstNumber"
                    placeholder="15-character GSTIN"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
                <div>
                  <label
                    for="partnerType"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Partner Type</label
                  >
                  <div class="relative">
                    <select
                      id="partnerType"
                      name="partnerType"
                      class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none font-medium pr-12"
                    >
                      {
                        partnerType.map((type) => (
                          <option value={type}>{type}</option>
                        ))
                      }
                    </select>
                    <div
                      class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-400"
                    >
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 9l-7 7-7-7"></path></svg
                      >
                    </div>
                  </div>
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="md:col-span-1">
                  <label
                    for="yearsInOperation"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Years in Operation</label
                  >
                  <input
                    type="number"
                    id="yearsInOperation"
                    name="yearsInOperation"
                    placeholder="In numbers (e.g., 5)"
                    min="0"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
                <div class="md:col-span-1">
                  <label
                    for="interestedProducts"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Interested Products</label
                  >
                  <div class="relative">
                    <select
                      id="interestedProducts"
                      name="interestedProducts"
                      class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none font-medium pr-12 truncate"
                    >
                      {
                        interestedProducts.map((type) => (
                          <option value={type}>{type}</option>
                        ))
                      }
                    </select>
                    <div
                      class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-400"
                    >
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 9l-7 7-7-7"></path></svg
                      >
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- Address Section -->
            <div class="space-y-6 pt-4">
              <h2 class="text-xl font-bold border-b pb-2 text-slate-800">
                Company Address
              </h2>

              <div>
                <label
                  for="street"
                  class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                  >Street details</label
                >
                <input
                  type="text"
                  id="street"
                  name="street"
                  placeholder="Flat, House no., Building, Company, Apartment"
                  class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                />
              </div>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                  <label
                    for="city"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >City</label
                  >
                  <input
                    type="text"
                    id="city"
                    name="city"
                    placeholder="City"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
                <div>
                  <label
                    for="state"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >State</label
                  >
                  <div class="relative">
                    <select
                      id="state"
                      name="state"
                      class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all appearance-none font-medium pr-12"
                    >
                      <option value="" disabled selected>Select state</option>
                      {
                        statesOfIndia.map((state) => (
                          <option value={state}>{state}</option>
                        ))
                      }
                    </select>
                    <div
                      class="absolute inset-y-0 right-0 flex items-center px-4 pointer-events-none text-slate-400"
                    >
                      <svg
                        class="h-5 w-5"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        ><path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M19 9l-7 7-7-7"></path></svg
                      >
                    </div>
                  </div>
                </div>
                <div>
                  <label
                    for="pincode"
                    class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                    >Zip Code</label
                  >
                  <input
                    type="number"
                    id="pincode"
                    name="pincode"
                    placeholder="6-digit PIN"
                    class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                  />
                </div>
              </div>
            </div>

            <!-- Other Info Section -->
            <div class="space-y-6 pt-4">
              <h2 class="text-xl font-bold border-b pb-2 text-slate-800">
                Additional Information
              </h2>

              <div>
                <label
                  class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                  >Website/Links</label
                >
                <div id="websiteInputs" class="space-y-3">
                  <div class="website-input-row flex gap-2">
                    <input
                      type="url"
                      name="websites[]"
                      placeholder="https://www.example.com"
                      class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium"
                    />
                    <!-- No delete button for the first input to match original logic or allow empty via script -->
                  </div>
                </div>
                <button
                  type="button"
                  id="addWebsiteBtn"
                  class="mt-3 text-blue-600 hover:text-blue-800 font-bold flex items-center gap-1 transition-colors group"
                >
                  <svg
                    class="w-5 h-5 group-hover:scale-110 transition-transform"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    ><path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M12 4v16m8-8H4"></path></svg
                  >
                  Add Website
                </button>
              </div>

              <div>
                <label
                  for="additionalMessage"
                  class="block text-sm font-bold text-slate-700 mb-2 uppercase tracking-wider"
                  >Additional Message</label
                >
                <textarea
                  id="additionalMessage"
                  name="additionalMessage"
                  rows="4"
                  placeholder="Leave a Message or Comment"
                  class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all resize-x-none font-medium"
                ></textarea>
              </div>
            </div>

            <!-- Submit Section -->
            <div
              class="pt-6 border-t border-slate-100 flex flex-col md:flex-row gap-4 items-center justify-end"
            >
              <button
                type="reset"
                id="resetBtn"
                class="w-full md:w-auto px-8 py-4 bg-white hover:bg-slate-50 text-blue-600 font-extrabold text-lg rounded-xl border border-blue-200 transition-colors"
              >
                Cancel
              </button>
              <button
                type="submit"
                id="submitBtn"
                class="w-full md:w-auto px-10 py-4 bg-[#2067e2] hover:bg-blue-700 text-white font-extrabold text-lg rounded-xl shadow-lg shadow-blue-500/25 transform transition-all active:scale-[0.98] flex items-center justify-center gap-3"
              >
                <span id="btnText">Submit Application</span>
                <svg
                  id="loadingIcon"
                  class="hidden animate-spin h-5 w-5 text-white"
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <circle
                    class="opacity-25"
                    cx="12"
                    cy="12"
                    r="10"
                    stroke="currentColor"
                    stroke-width="4"></circle>
                  <path
                    class="opacity-75"
                    fill="currentColor"
                    d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"
                  ></path>
                </svg>
              </button>
            </div>

            <!-- Status Message -->
            <div
              id="formStatus"
              class="hidden p-4 rounded-xl text-center font-bold"
            >
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  // Add dynamic website field
  const addWebsiteBtn = document.getElementById("addWebsiteBtn");
  const websiteInputs = document.getElementById("websiteInputs");

  addWebsiteBtn?.addEventListener("click", () => {
    const row = document.createElement("div");
    row.className = "website-input-row flex gap-2 items-center";
    row.innerHTML = `
      <input type="url" name="websites[]" placeholder="https://www.example.com"
        class="w-full px-5 py-4 rounded-xl bg-slate-50 border border-slate-200 text-slate-900 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium" />
      <button type="button" class="remove-website-btn text-slate-400 hover:text-red-500 p-3 transition-colors rounded-lg bg-slate-100 hover:bg-red-50" aria-label="Remove URL">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
      </button>
    `;
    websiteInputs?.appendChild(row);

    // Attach listener to new remove button
    const removeBtn = row.querySelector(".remove-website-btn");
    removeBtn?.addEventListener("click", () => {
      row.remove();
    });
  });

  // Handle form submission
  const form = document.getElementById("partnerForm") as HTMLFormElement;
  const submitBtn = document.getElementById("submitBtn") as HTMLButtonElement;
  const btnText = document.getElementById("btnText");
  const loadingIcon = document.getElementById("loadingIcon");
  const formStatus = document.getElementById("formStatus");
  const resetBtn = document.getElementById("resetBtn");

  // Extract UTM parameters
  const urlParams = new URLSearchParams(window.location.search);
  const utmParams = {
    utmSource: urlParams.get("utm_source") || "",
    utmTerm: urlParams.get("utm_term") || "",
    utmMedium: urlParams.get("utm_medium") || "",
    utmCampaign: urlParams.get("utm_campaign") || "",
    utmContent: urlParams.get("utm_content") || "",
  };

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();

    // Set loading state
    submitBtn.disabled = true;
    if (btnText) btnText.textContent = "Submitting...";
    loadingIcon?.classList.remove("hidden");
    formStatus?.classList.add("hidden");

    const formData = new FormData(form);
    const data = Object.fromEntries(formData.entries());

    // Website fields are arrays, handle them separately
    const websites = formData.getAll("websites[]").filter(Boolean).join(", ");

    const payload = {
      leadListId: "68d62059f0d45f9cd1074891",
      name: data.yourName || "",
      email: data.email || "",
      contact1: data.contactNumber || "",
      address: {
        City: data.city || "",
        state: data.state || "",
        pincode: data.pincode || "",
        streetAddress: data.street || "",
      },
      customFields: [
        {
          customFieldId: "6839353dbfaf99e09d8c633c",
          key: "custom_leads_source",
          value: utmParams.utmSource,
        },
        {
          customFieldId: "68393882bfaf99e09d8c8a55",
          key: "utm_term",
          value: utmParams.utmTerm,
        },
        {
          customFieldId: "683938a2bfaf99e09d8c8c9e",
          key: "utm_medium",
          value: utmParams.utmMedium,
        },
        {
          customFieldId: "683938b4bfaf99e09d8c8dc9",
          key: "utm_campaign",
          value: utmParams.utmCampaign,
        },
        {
          customFieldId: "683938cdbfaf99e09d8c8e21",
          key: "utm_content",
          value: utmParams.utmContent,
        },
        {
          customFieldId: "68b53c9b5188bd06232e96a9",
          key: "nialabs_message",
          value: data.additionalMessage || "",
        },
        {
          customFieldId: "68d6212ef0d45f9cd1076150",
          key: "company_name",
          value: data.companyName || "",
