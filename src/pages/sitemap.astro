---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

// Using the links provided in the React component
const sitemapLinks = [
  { name: "Home", url: "/" },
  { name: "About Us", url: "/aboutUs" },
  { name: "Biometric Attendance System", url: "/products/biometric-attendance-machine" },
  { name: "Student Response System", url: "/student-response-system" },
  { name: "Contact Us", url: "/contactUs" },
  { name: "API Docs", url: "/docs" },
  { name: "Blogs", url: "https://blogs.nialabs.in", external: true },
  { name: "Download Brochure", url: "/NiaLabs_Machines_Brochure.pdf", download: true, external: true },
  { name: "FAQs", url: "/faqs" },
  { name: "AI vs Traditional Attendance Systems", url: "/ai-biometric-vs-traditional-attendance-systems" },
  { name: "Bus Attendance System", url: "/bus-attendance-system" },
  { name: "Biometric Attendance System in Ahmedabad", url: "/biometric-attendance-system-in-ahmedabad" },
  { name: "Biometric Attendance System in Bangalore", url: "/biometric-attendance-system-in-bangalore" },
  { name: "Biometric Attendance System in Chandigarh", url: "/biometric-attendance-system-in-chandigarh" },
  { name: "Biometric Attendance System in Chennai", url: "/biometric-attendance-system-in-chennai" },
  { name: "Biometric Attendance System in Coimbatore", url: "/biometric-attendance-system-in-coimbatore" },
  { name: "Biometric Attendance System in Delhi", url: "/biometric-attendance-system-in-delhi" },
  { name: "Biometric Attendance System in Gujarat", url: "/biometric-attendance-system-in-gujarat" },
  { name: "Biometric Attendance System in Gurugram", url: "/biometric-attendance-system-in-gurugram" },
  { name: "Biometric Attendance System in Hyderabad", url: "/biometric-attendance-system-in-hyderabad" },
  { name: "Biometric Attendance System in Maharashtra", url: "/biometric-attendance-system-in-maharashtra" },
  { name: "Biometric Attendance System in Nagpur", url: "/biometric-attendance-system-in-nagpur" },
  { name: "Biometric Attendance System in Pune", url: "/biometric-attendance-system-in-pune" },
  { name: "Become a Partner", url: "/become-a-partner" },
  { name: "Privacy Policy", url: "/privacy-policy" },
  { name: "Terms and Conditions", url: "/terms-and-conditions" },
  { name: "Return Policy", url: "/return-policy" },
  { name: "UHF Reader", url: "/uhf-rfid-reader" },
  { name: "RFID Cards", url: "/rfid-cards" },
  { name: "Access Control System", url: "/4-door-access-control-panel" },
  { name: "UHF RFID Card", url: "/uhf-card" },
  { name: "Tripod Turnstile", url: "/tripod-turnstile" },
  { name: "Near Field Communication", url: "/nfc-card" },
  { name: "Face Recognition Attendance System", url: "/face-recognition-attendance-system" },
  { name: "SiteMap", url: "/sitemap" }
];
---

<Layout title="Best Biometric Attendance System in India " description="Nialabs offers the best biometric attendance system in India with fast face recognition, accurate attendance tracking, cloud reports, and seamless integration for all industries.">
  <Navbar />
  
  <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-10 md:py-20">
    <h1 class="text-center text-3xl font-bold text-slate-800 md:text-4xl lg:text-5xl md:mt-10 mb-10 md:mb-20">
      SiteMap
    </h1>
    
    <div class="flex flex-wrap justify-center gap-4 mx-1 md:mx-10 lg:mx-[15%] mb-10 md:mb-40">
      {sitemapLinks.map((link) => (
        <a 
          href={link.url}
          target={link.external ? "_blank" : undefined}
          rel={link.external ? "noopener noreferrer" : undefined}
          download={link.download ? "" : undefined}
          class="inline-flex items-center justify-center rounded-md border border-teal-500 px-4 py-2 text-sm font-semibold text-teal-600 transition-colors hover:bg-teal-50 hover:text-teal-700 focus:outline-none focus:ring-2 focus:ring-teal-500 focus:ring-offset-2 active:scale-95"
        >
          {link.name}
        </a>
      ))}
    </div>
  </main>
</Layout>
