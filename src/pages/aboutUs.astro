---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AboutHero from '../components/AboutHero.astro';
import CompanyJourney from '../components/CompanyJourney.astro';
import CompanyValues from '../components/CompanyValues.astro';
import AboutIndustries from '../components/AboutIndustries.astro';
import AboutCta from '../components/AboutCta.astro';

// SEO data
const title = "About Nialabs – Leading Biometric Attendance & Access Control Solutions";
const description = "At Nialabs, we combine biometric innovation with cloud-based technology to deliver secure, seamless, and future-ready attendance and access control systems.";
---

<Layout title={title} description={description}>
    <Navbar />
    <main>
        <AboutHero />
        <CompanyJourney />
        <CompanyValues />
        <AboutIndustries />
        <AboutCta />
    </main>
</Layout>
