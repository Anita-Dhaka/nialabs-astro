---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import AboutHero from '../components/AboutHero.astro';
import CompanyJourney from '../components/CompanyJourney.astro';
import CompanyValues from '../components/CompanyValues.astro';
import AboutIndustries from '../components/AboutIndustries.astro';
import AboutCta from '../components/AboutCta.astro';

// SEO data
const title = "About Nialabs – Leading Biometric Attendance & Access Control Solutions in India";
const description = "India’s trusted provider of AI-powered biometric attendance, cloud-connected access control systems & smart workforce tracking for schools, enterprises & institutions.";
---

<Layout title={title} description={description}>
    <Navbar />
    <main>
        <AboutHero />
        <CompanyJourney />
        <CompanyValues />
        <AboutIndustries />
        <AboutCta />
    </main>
</Layout>
