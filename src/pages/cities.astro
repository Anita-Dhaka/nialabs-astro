---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import {cityData} from '../data/cityData';
const switchingCities = ["Multiple Cities", ...cityData.map((c: any) => c.heading)];
---

<Layout>
    <Navbar />
    <main class="bg-slate-50 min-h-screen">

<section class="relative min-h-[80vh] flex items-center justify-center overflow-hidden bg-gray-900">

  <!-- Background -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1633412802994-5c058f151b66?auto=format&fit=crop&q=80&w=1920"
      alt="High-tech facial recognition attendance interface"
      class="w-full h-full object-cover opacity-40"
      referrerpolicy="no-referrer"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-[#050f28]/90 via-[#0a1e50]/70 to-[#0f2864]/50"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 text-center px-4 max-w-5xl mx-auto">

    <!-- Badge -->
    <div class="inline-block mb-6 px-3 py-1 text-[10px] md:text-xs font-bold uppercase tracking-widest bg-blue-500 text-white rounded-full border border-blue-900">
      Excellence in Biometrics and Attendance Systems
    </div>

    <!-- Heading -->
    <h1 class="text-3xl md:text-6xl font-bold text-white mb-6 leading-tight">
      We provide solutions in <br />

      <!-- Animated text -->
      <span id="city-text"
        class="inline-block min-w-[300px] bg-gradient-to-r from-blue-300 via-blue-400 to-blue-500 bg-clip-text text-transparent transition-all duration-300">
        Multiple Cities
      </span>
    </h1>

    <!-- Description -->
    <p class="text-white/80 text-base md:text-xl max-w-2xl mx-auto mb-10 font-light">
      NiaLabs is committed to delivering state-of-the-art biometric and attendance tracking solutions across India's major industrial and corporate hubs.
    </p>

    <!-- Button -->
    <button
      onclick="document.getElementById('cities')?.scrollIntoView({ behavior: 'smooth' })"
      class="inline-flex items-center gap-2 px-8 py-4 bg-blue-600 text-white font-semibold rounded-xl shadow-2xl hover:scale-105 active:scale-95 transition-all"
    >
      Explore Cities →
    </button>
  </div>
</section>

<section id="cities" class="py-20">
  <div class="max-w-7xl mx-auto px-4">

    <!-- Heading -->
    <div class="max-w-2xl mb-12">
      <h2 class="text-3xl font-bold text-gray-900 mb-4">
        Our Service Locations
      </h2>
      <p class="text-gray-500 text-lg">
        Explore our wide network of service centers providing cutting-edge biometric attendance and security solutions.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

      {cityData.map((city, index) => (
        <div
          class="group bg-white rounded-[24px] overflow-hidden border border-gray-200 shadow-sm hover:shadow-2xl transition-all duration-300 cursor-pointer hover:-translate-y-2"
          onclick={`window.location.href='/${city.route}'`}
        >

          <!-- Image -->
          <div class="relative h-56 overflow-hidden">
            <img
              src={city.image}
              alt={city.heading}
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />

            <div class="absolute inset-0 bg-gradient-to-t from-gray-900 to-transparent flex items-end p-6">
              <h3 class="text-white font-bold text-lg">
                {city.heading}
              </h3>
            </div>
          </div>

          <!-- Content -->
          <div class="p-6">
            <p class="text-gray-500 text-sm mb-6 line-clamp-2">
              {city.metaDesc}
            </p>

            <div class="text-blue-600 font-medium flex items-center gap-1 group-hover:text-blue-700">
              View Solutions →
            </div>
          </div>

        </div>
      ))}

    </div>
  </div>
</section>
    </main>
</Layout>

<script define:vars={{ switchingCities }}>
  const cities = switchingCities;
  let index = 0;

  const el = document.getElementById("city-text");

if (el) {
  setInterval(() => {
    index = (index + 1) % cities.length;

    el.style.opacity = 0;
    el.style.transform = "translateY(10px)";

    setTimeout(() => {
      el.textContent = cities[index];
      el.style.opacity = 1;
      el.style.transform = "translateY(0)";
    }, 300);
  }, 2500);
}

  setInterval(() => {
    index = (index + 1) % cities.length;

    el.style.opacity = 0;
    el.style.transform = "translateY(10px)";

    setTimeout(() => {
      el.textContent = cities[index];
      el.style.opacity = 1;
      el.style.transform = "translateY(0)";
    }, 300);
  }, 2500);
</script>