---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import ProductHero from '../components/ProductHero.astro';
import ProcessSteps from '../components/ProcessSteps.astro';
import Footer from '../components/Footer.astro';
import HomeCta from '../components/HomeCta.astro';

const headerData = {
    title: "Interactive Student Response System for Modern Classrooms",
    desc: "Improve classroom participation with real-time polling, quizzes, and instant feedback.",
    image: "/response/clicker-landing.png",
};

const benefitsData = [
    {
        title: "Conduct Quiz",
        desc: "Easily create and manage quizzes to assess student knowledge. Simplify evaluation with AI-driven insights and performance tracking. Encourage active participation and measure understanding effectively.",
        icon: "quiz"
    },
    {
        title: "Empower Classroom Learning",
        desc: "Enhance teaching with tools that boost engagement. Enable personalized learning experiences tailored to student needs. Support teachers with innovative resources to improve outcomes.",
        icon: "learning"
    },
    {
        title: "Conduct Inter-Intra House Competitions",
        desc: "Organize house-based competitions to build teamwork and school spirit. Promote healthy rivalry and foster collaboration among students. Recognize achievements and encourage participation across all levels.",
        icon: "competition"
    },
    {
        title: "Track Time Spent",
        desc: "Gain insights into how students allocate their time. Identify strengths and weaknesses through detailed analytics. Use data to personalize feedback and improve learning strategies.",
        icon: "time"
    },
    {
        title: "Real-Time Reporting",
        desc: "Stay informed with live updates and actionable data. Monitor progress and performance anytime, anywhere. Empower decision-making with comprehensive reporting and insights.",
        icon: "report"
    }
];

const howItWorks = {
  title: "How the Student Response System Works",
  steps: [
    {
      title: "Teacher Ask Questions",
      icon: "enrollment",
      details: [
        "Empower teachers to ask interactive questions during lessons using Nialabs Clicker software.",
        "Engage students in real-time and assess their understanding with ease. Simplify classroom interactions and promote active learning."
      ]
    },
    {
      title: "Students Respond With Clicker",
      icon: "matching",
      details: [
        "Enable students to respond instantly using clickers, making learning interactive and engaging.",
        "Gather immediate feedback to identify comprehension levels and foster active participation in classroom activities."
      ]
    },
    {
      title: "Teachers See Data and Take Action",
      icon: "capture",
      details: [
        "Provide teachers with real-time data insights to assess student performance effectively.",
        "Use actionable analytics to address gaps, improve learning outcomes, and make informed decisions to tailor teaching strategies."
      ]
    }
  ]
};

// Creating an array of client logo paths mapping exactly to the folder contents (taking a selection of 20 for the marquee)
const clientLogos = Array.from({ length: 20 }, (_, i) => `/response/clients/client_logo_${i + 1}.jpg`);

const title = "Student Response System | Real-Time Polling & Feedback | Nialabs";
const description = "Nialabs Student Response System enables real-time polling, quizzes & feedback in classrooms. Engage students, track responses & boost learning with interactive technology.";
---

<Layout title={title} description={description}>
    <Navbar />
    <main class="bg-white overflow-hidden">
        
        <!-- Hero Section -->
        <ProductHero 
            title={headerData.title}
            desc={headerData.desc}
            image={headerData.image}
            badge="Smart Classroom Tech"
            primaryButtonText="Book a Demo"
        />

        <!-- Trusted By Marquee -->
        <section class="py-10 bg-slate-50 border-b border-slate-100 overflow-hidden relative">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8 text-center">
                <p class="font-bold text-slate-500 tracking-wider uppercase text-sm">Trusted by 8,000+ classrooms PAN India</p>
            </div>
            
            <div class="relative flex overflow-x-hidden group">
                <div class="animate-marquee whitespace-nowrap flex shrink-0 items-center gap-12 sm:gap-16 px-6">
                    {clientLogos.map((logo) => (
                        <img src={logo} alt="Client Logo" class="h-12 md:h-16 w-auto max-w-[140px] object-contain hover:scale-105 transition-all duration-300" loading="lazy" />
                    ))}
                </div>
                <!-- Duplicate for seamless loop -->
                <div class="animate-marquee whitespace-nowrap flex shrink-0 items-center gap-12 sm:gap-16 px-6" aria-hidden="true">
                    {clientLogos.map((logo) => (
                        <img src={logo} alt="Client Logo" class="h-12 md:h-16 w-auto max-w-[140px] object-contain hover:scale-105 transition-all duration-300" loading="lazy" />
                    ))}
                </div>
            </div>
            
            <!-- Gradient fades for marquee edges -->
            <div class="absolute inset-y-0 left-0 w-24 bg-gradient-to-r from-slate-50 to-transparent pointer-events-none"></div>
            <div class="absolute inset-y-0 right-0 w-24 bg-gradient-to-l from-slate-50 to-transparent pointer-events-none"></div>
        </section>

        <!-- Intro Section -->
        <section class="py-20 relative bg-white pb-10">
            <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
                <div class="inline-flex items-center justify-center gap-3 mb-6">
                    <div class="w-12 h-1 bg-blue-600 rounded-full"></div>
                    <p class="text-sm font-black text-blue-600 uppercase tracking-widest">What is SRS?</p>
                    <div class="w-12 h-1 bg-blue-600 rounded-full"></div>
                </div>
                <h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight leading-tight mb-8">
                    Transforming Classrooms into <br class="hidden md:block" />
                    <span class="text-blue-600">Interactive Spaces</span>
                </h2>
                <div class="space-y-6 text-lg md:text-xl text-slate-600 leading-relaxed font-medium">
                    <p>
                        Evolving from traditional Clickers, Student Response Systems (SRS) transform classrooms into dynamic, interactive learning spaces.
                    </p>
                    <p>
                        With instant polls, engaging quizzes, and collaborative competitions, students actively participate like never before. Monitor student progress in real time, track engagement, and access instant feedback through intuitive dashboards all at your fingertips.
                    </p>
                </div>
            </div>
        </section>

        <!-- Benefits Section (Custom Grid) -->
        <section class="py-20 relative bg-white">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
                <div class="text-center max-w-3xl mx-auto mb-16">
                    <h2 class="text-3xl md:text-5xl font-black text-slate-900 tracking-tight leading-tight mb-6">Benefits of Student Response System</h2>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                    {benefitsData.map((benefit, index) => (
                        <div class="bg-slate-50 rounded-[32px] p-8 border border-slate-100 hover:shadow-2xl hover:shadow-blue-500/10 hover:border-blue-100 transition-all duration-500 group">
                            <div class="w-14 h-14 rounded-2xl bg-white shadow-md flex items-center justify-center text-blue-600 mb-6 group-hover:scale-110 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
                                {benefit.icon === 'quiz' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><path d="M9 15L11 15"/><path d="M9 11L15 11"/></svg>}
                                {benefit.icon === 'learning' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>}
                                {benefit.icon === 'competition' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 9H4.5a2.5 2.5 0 0 1 0-5H6"/><path d="M18 9h1.5a2.5 2.5 0 0 0 0-5H18"/><path d="M4 22h16"/><path d="M10 14.66V17c0 .55-.47.98-.97 1.21C7.85 18.75 7 20.24 7 22"/><path d="M14 14.66V17c0 .55.47.98.97 1.21C16.15 18.75 17 20.24 17 22"/><path d="M18 2H6v7a6 6 0 0 0 12 0V2z"/></svg>}
                                {benefit.icon === 'time' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>}
                                {benefit.icon === 'report' && <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>}
                            </div>
                            <h3 class="text-xl font-bold text-slate-900 mb-4">{benefit.title}</h3>
                            <p class="text-slate-600 font-medium leading-relaxed">{benefit.desc}</p>
                        </div>
                    ))}
                </div>
            </div>
            
            <!-- Images matching original context -->
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-20">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center border-[6px] border-slate-50 rounded-[40px] overflow-hidden bg-white shadow-2xl">
                 <div class="p-12 text-center md:text-left flex flex-col justify-center h-full">
                    <h3 class="text-3xl font-black tracking-tight text-slate-900 mb-4">Teacher Remote</h3>
                    <p class="text-lg text-slate-500 font-medium leading-relaxed">Empower teachers to ask interactive questions during lessons using Nialabs Clicker. Engage students in real-time and assess their understanding with ease. Simplify classroom interactions and promote active learning.</p>
                 </div>
                 <div class="bg-blue-50/50 flex items-center justify-center p-8 h-full">
                    <img src="/response/teacher.png" alt="Teacher Remote" class="max-h-80 w-auto object-contain drop-shadow-2xl hover:scale-105 transition-transform duration-500" />
                 </div>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-center border-[6px] border-slate-50 rounded-[40px] overflow-hidden bg-white shadow-2xl mt-8">
                 <div class="bg-indigo-50/50 flex items-center justify-center p-8 h-full order-last md:order-first">
                    <img src="/response/student.png" alt="Student Clicker" class="max-h-80 w-auto object-contain drop-shadow-2xl hover:scale-105 transition-transform duration-500" />
                 </div>
                 <div class="p-12 text-center md:text-left flex flex-col justify-center h-full">
                    <h3 class="text-3xl font-black tracking-tight text-slate-900 mb-4">Students Clicker</h3>
                    <p class="text-lg text-slate-500 font-medium leading-relaxed">Enable students to respond instantly using clickers, making learning interactive and engaging. Gather immediate feedback to identify comprehension levels. Foster active participation in classroom activities.</p>
                 </div>
              </div>
            </div>
        </section>

        <!-- Process Steps -->
        <ProcessSteps 
            title={howItWorks.title}
            subtitle={howItWorks.subtitle}
            steps={howItWorks.steps}
        />

        <!-- Get In Touch -->
        <HomeCta />

    </main>
    <Footer />
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
  @keyframes marquee {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }
  @keyframes marquee2 {
    0% { transform: translateX(0%); }
    100% { transform: translateX(-100%); }
  }
  .animate-marquee {
    animation: marquee 25s linear infinite;
  }
  .animate-marquee2 {
    animation: marquee2 25s linear infinite;
  }
  /* Pause animation on hover */
  .group:hover .animate-marquee,
  .group:hover .animate-marquee2 {
    animation-play-state: paused;
  }
</style>


