---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';
import docsMeta from '../../content/docs/_meta.json';

export async function getStaticPaths() {
  const docsEntries = await getCollection('docs');
  return docsEntries.map(entry => ({
    params: { slug: entry.id === 'index' ? undefined : entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

// Find the label from meta
const idKey = entry.id === 'index' ? 'index' : entry.id;
const pageTitle = docsMeta[idKey as keyof typeof docsMeta] || entry.data.title || entry.id;

const breadcrumbs = [
  { label: pageTitle }
];
---

<DocsLayout 
  title={`${pageTitle} - Nialabs Documentation`} 
  description={entry.data.description || `Documentation for ${pageTitle}`}
  breadcrumbs={breadcrumbs}
>
  <Content />
</DocsLayout>
