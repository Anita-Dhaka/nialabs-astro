---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import BiometricHero from "../components/BiometricHero.astro";
import BiometricCta from "../components/BiometricCta.astro";
import ProductIndustries from "../components/ProductIndustries.astro";
import Products from "../components/Products.astro";
import BiometricFeatures from  "../components/BiometricFeatures.astro"

const howItWorks = [
  { bold: "100% Secure Data Management", text: "No risk of data theft." },
  {
    bold: "Real-time Attendance Tracking",
    text: "Instant insights for HR, admins, and parents.",
  },
  {
    bold: "Seamless Integration",
    text: "Works with payroll, school ERP, and transport systems.",
  },
  {
    bold: "Scalable Solutions",
    text: "From small businesses to large enterprises.",
  },
];

const testimonials = {
  title: "What Our Clients Say",
  points: [
    {
      desc: "\u201c The biometric attendance system by Nialabs is so simple to use. Even our non-technical staff can operate it easily. This is what we were looking for in a biometric attendance machine.\u201d",
      position: "Rysen Group,",
      district: "Jaipur",
    },
    {
      desc: "\u201cThe support team of Nialabs is always ready to help. They were supportive from the beginning and solved whatever queries we had. Due to their constant support, the process remained worry-free for us.\u201d",
      position: "The Srijam School,",
      district: "New Delhi",
    },
    {
      desc: "\u201cBy installing Nialabs' biometric machines, all our school operations became smoother. From attendance tracking to payroll management and generating reports, all operations are streamlined.\u201d",
      position: "Dhruva International,",
      place: "Jaipur",
    },
  ],
};

const industries = {
  title: "Industries We Serve",
  points: [
    {
      icon: "/headerImages/industries/school.webp",
      title: "Schools / Colleges",
      desc: "Smart attendance with parent communication",
    },
    {
      icon: "/headerImages/industries/cowork.webp",
      title: "Corporate Offices",
      desc: "Payroll management and workforce monitoring",
    },
    {
      icon: "/headerImages/industries/enterprise.webp",
      title: "Manufacturing Units",
      desc: "Track shifts and productivity with ease.",
    },
    {
      icon: "/headerImages/industries/parking.webp",
      title: "Transport Fleets",
      desc: "GPS-enabled Smart bus attendance system.",
    },
    {
      icon: "/headerImages/industries/Healthcare.webp",
      title: "Hospitals",
      desc: "Monitor staff shifts and patient attendance efficiently.",
    },
    {
      icon: "/headerImages/industries/retail.webp",
      title: "Retail Stores",
      desc: "Manage employee schedules and customer service tracking.",
    },
  ],
};

// SEO data
const title =
  "Best Biometric Attendance System in India ";
const description =
  "Nialabs offers the best biometric attendance system in India with fast face recognition, accurate attendance tracking, cloud reports, and seamless integration for all industries.";
---

<Layout title={title} description={description}>
  <Navbar />
  <main>
    <BiometricHero />
    <section class="py-20 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 items-center">
          <div>
            <h2 class="text-3xl font-extrabold text-gray-900 mb-4">
              Why Organisations Choose to Grow with NIALABS
            </h2>
            <p class="mb-6">
              Nialabs combines AI-driven Biometric technology with Cloud-based
              API's, giving your organisation a complete attendance platform
              that is accurate, secure, and effortless to use.
            </p>
            <ul class="space-y-6">
              {
                howItWorks.map((step, index) => (
                  <li class="flex items-start">
                    <div class="flex-none bg-blue-600 text-white w-8 h-8 rounded-full flex items-center justify-center font-bold mr-4 mt-1">
                      {index + 1}
                    </div>
                    <p class="text-gray-600 text-lg">
                      <span class="font-bold">{step.bold}: </span>
                      {step.text}
                    </p>
                  </li>
                ))
              }
            </ul>
          </div>
          <div
            class="bg-gray-50 p-8 rounded-3xl shadow-lg border border-gray-100"
          >
            <div class="relative order-2 lg:order-1">
              <div class="absolute -inset-4 bg-blue-500/5 rounded-3xl blur-2xl">
              </div>
              <div
                class="relative rounded-[32px] overflow-hidden shadow-2xl border border-slate-200 bg-white h-80 md:h-100 flex items-center justify-center"
              >
                <video
                  class="w-auto h-full object-cover"
                  autoplay
                  loop
                  muted
                  playsinline
                >
                  <source
                    src="/mainImages/nialabs_media.mp4"
                    type="video/mp4"
                  />
                  Your browser does not support the video tag.
                </video>

                <!-- Decorative overlay -->
                <div
                  class="absolute inset-0 ring-1 ring-inset ring-black/5 pointer-events-none rounded-[32px]"
                >
                </div>

                <!-- Play hint or badge -->
                <div
                  class="absolute bottom-6 left-6 px-4 py-2 bg-white/90 backdrop-blur-md rounded-xl shadow-lg border border-white/20"
                >
                  <div class="flex items-center gap-2">
                    <span
                      class="flex h-2 w-2 rounded-full bg-blue-600 animate-pulse"
                    ></span>
                    <span
                      class="text-xs font-bold text-slate-800 uppercase tracking-wider"
                      >Product Showcase</span
                    >
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    <BiometricFeatures />
    <Products />
    {/* Industries */}
    {
      industries && (
        <ProductIndustries
          title={industries.title}
          items={industries.points.map((p, i) => ({
            title: p.title,
            text: p.desc,
            image: p.icon || "/uhfReader/enterprise.webp",
          }))}
        />
      )
    }
    {
      testimonials && (
        <section class="py-24 bg-slate-900 relative overflow-hidden">
          <div class="absolute inset-0 opacity-20 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-blue-400 via-transparent to-transparent" />
          <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
            <div class="text-center max-w-3xl mx-auto mb-16">
              <h2 class="text-3xl md:text-5xl font-extrabold text-white mb-6 leading-tight">
                {testimonials.title}
              </h2>
              <div class="w-16 h-1.5 bg-blue-500 rounded-full mx-auto mb-8" />
            </div>
            <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-3 gap-6">
              {testimonials.points.map((t) => (
                <div class="bg-white/5 backdrop-blur-sm rounded-3xl p-8 border border-white/10 flex flex-col justify-between hover:bg-white/10 transition-colors duration-300">
                  <div class="mb-8 relative">
                    <svg
                      class="w-8 h-8 text-blue-500/30 absolute -top-4 -left-4"
                      fill="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
                    </svg>
                    <p class="text-slate-300 leading-relaxed relative z-10 text-sm italic">
                      {t.desc.replace(/^“|”$/g, "")}
                    </p>
                  </div>
                  <div class="flex items-center gap-4">
                    <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white font-bold text-lg shrink-0">
                      {t.position.charAt(0)}
                    </div>
                    <div>
                      <h4 class="text-white font-bold text-sm">{t.position}</h4>
                      <p class="text-slate-400 text-xs">
                        {t.place} {t.district && `${t.district}`}
                      </p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>
      )
    }
    <BiometricCta />
  </main>
</Layout>
