---
import Layout from './Layout.astro';
import Navbar from '../components/Navbar.astro';
import DocsSidebar from '../components/DocsSidebar.astro';
import DocsBreadcrumbs from '../components/DocsBreadcrumbs.astro';

const { title, description, breadcrumbs } = Astro.props;
---

<Layout title={title} description={description}>
  <Navbar />
  
  <div class="flex-grow flex flex-col md:flex-row max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8">
    <DocsSidebar />
    
    <main class="flex-grow py-8 md:pl-8 lg:pl-12 min-w-0">
      <DocsBreadcrumbs items={breadcrumbs} />
      
      <article class="prose prose-slate max-w-none prose-headings:scroll-mt-20 prose-headings:font-bold prose-a:text-blue-600 prose-pre:bg-slate-900 prose-pre:text-slate-50">
        <slot />
      </article>
      
      {/* Optional: Add "On This Page" / Table of Contents sidebar here on the right */}
    </main>
  </div>
</Layout>

<style is:global>
  @reference "../styles/global.css";

  /* Documentation-specific styles for the prose class */
  .prose h1 {
    @apply text-3xl font-extrabold text-slate-900 mb-4;
  }
  .prose h2 {
    @apply text-2xl font-bold text-slate-900 mt-10 mb-4 border-b border-slate-200 pb-2;
  }
  .prose h3 {
    @apply text-xl font-bold text-slate-900 mt-8 mb-4;
  }
  .prose p {
    @apply text-slate-600 leading-relaxed mb-4;
  }
  .prose ul {
    @apply list-disc list-inside space-y-2 mb-4 text-slate-600;
  }
  .prose ol {
    @apply list-decimal list-inside space-y-2 mb-4 text-slate-600;
  }
  .prose code {
    @apply bg-slate-100 text-pink-600 px-1 py-0.5 rounded text-sm font-mono;
  }
  .prose pre {
    @apply p-4 rounded-lg overflow-x-auto my-6;
  }
  .prose pre code {
    @apply bg-transparent text-inherit p-0;
  }
  .prose blockquote {
    @apply border-l-4 border-slate-200 pl-4 italic text-slate-500 my-6;
  }
  .prose img {
    @apply rounded-xl shadow-sm my-8;
  }
  .prose table {
    @apply w-full text-left border-collapse my-6;
  }
  .prose th {
    @apply border-b-2 border-slate-200 py-3 font-semibold text-slate-900;
  }
  .prose td {
    @apply border-b border-slate-100 py-3 text-slate-600;
  }
</style>
